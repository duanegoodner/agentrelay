direction: down

classes: {
  composition: {
    style.stroke: "#333333"
  }
  dependency: {
    style.stroke-dash: 3
  }
  inheritance: {
    target-arrowhead.shape: triangle
    style.stroke: "#333333"
  }
  implementation: {
    style.stroke-dash: 3
    target-arrowhead.shape: triangle
  }
}

TaskManifest: "TaskManifest <<frozen dataclass>>" {
  shape: class
  schema_version: str
  task_id: str
  role: AgentRole
  description: "str | None"
  src_paths: "tuple[Path, ...]"
  test_paths: "tuple[Path, ...]"
  spec_path: "Path | None"
  branch_name: str
  integration_branch: str
  attempt_num: int
  graph_name: "str | None"
  dependencies: "dict[str, DependencyInfo]"
}

DependencyInfo: "DependencyInfo <<frozen dataclass>>" {
  shape: class
  description: "str | None"
}

WorkflowPolicies: "WorkflowPolicies <<frozen dataclass>>" {
  shape: class
  schema_version: str
  commit_policy: "CommitPolicy | None"
  pr_policy: "PrPolicy | None"
  completion_gate: "CompletionGatePolicy | None"
  review: "ReviewPolicy | None"
  adr: "AdrPolicy | None"
  verification: "VerificationPolicy | None"
}

WorkflowAction: "WorkflowAction <<str>>" {
  shape: class
  COMMIT_AND_PUSH
  CREATE_PR
  SIGNAL_DONE
  SIGNAL_FAILED
  RUN_COMPLETION_GATE
  RECORD_CONCERN
  WRITE_ADR
  RUN_VERIFICATION
}

PrBodySection: "PrBodySection <<str>>" {
  shape: class
  SUMMARY
  FILES_CHANGED
}

CommitPolicy: "CommitPolicy <<frozen dataclass>>" {
  shape: class
  action: WorkflowAction
}

PrPolicy: "PrPolicy <<frozen dataclass>>" {
  shape: class
  action: WorkflowAction
  base_branch: str
  title_template: str
  body_sections: "tuple[PrBodySection, ...]"
}

CompletionGatePolicy: "CompletionGatePolicy <<frozen dataclass>>" {
  shape: class
  command: str
  max_attempts: int
  output_file: str
}

VerificationPolicy: "VerificationPolicy <<frozen dataclass>>" {
  shape: class
  commands: "tuple[str, ...]"
}

AdrPolicy: "AdrPolicy <<frozen dataclass>>" {
  shape: class
  verbosity: AgentVerbosity
}

ReviewPolicy: "ReviewPolicy <<frozen dataclass>>" {
  shape: class
  model: "str | None"
  review_on_attempt: int
}

manifest_functions: "manifest_functions <<module>>" {
  shape: class
  module_path: agent_comm_protocol.manifest
  +build_manifest(task, branch_name, integration_branch, graph_name, attempt_num, dependency_descriptions): TaskManifest
  +manifest_to_dict(manifest): dict
}

policies_functions: "policies_functions <<module>>" {
  shape: class
  module_path: agent_comm_protocol.policies
  +build_policies(task, integration_branch, default_max_gate_attempts): WorkflowPolicies
  +policies_to_dict(policies): dict
}

templates_functions: "templates_functions <<module>>" {
  shape: class
  module_path: agent_comm_protocol.templates
  +resolve_instructions(role, manifest, adapter_name): str
}

# Relationships
TaskManifest -> DependencyInfo: dependencies { class: composition }
WorkflowPolicies -> CommitPolicy: commit_policy (optional) { class: composition }
WorkflowPolicies -> PrPolicy: pr_policy (optional) { class: composition }
WorkflowPolicies -> CompletionGatePolicy: completion_gate (optional) { class: composition }
WorkflowPolicies -> ReviewPolicy: review (optional) { class: composition }
WorkflowPolicies -> AdrPolicy: adr (optional) { class: composition }
WorkflowPolicies -> VerificationPolicy: verification (optional) { class: composition }
CommitPolicy -> WorkflowAction: action { class: composition }
PrPolicy -> WorkflowAction: action { class: composition }
PrPolicy -> PrBodySection: body_sections { class: composition }
manifest_functions -> TaskManifest: builds { class: composition }
policies_functions -> WorkflowPolicies: builds { class: composition }
templates_functions -> TaskManifest: reads { class: composition }
