direction: down

classes: {
  composition: {
    style.stroke: "#333333"
  }
  dependency: {
    style.stroke-dash: 3
  }
  inheritance: {
    target-arrowhead.shape: triangle
    style.stroke: "#333333"
  }
  implementation: {
    style.stroke-dash: 3
    target-arrowhead.shape: triangle
  }
}

IntegrationBoundary: "IntegrationBoundary <<enumeration>>" {
  shape: class
  WORKSPACE
  SIGNAL
  PULL_REQUEST
  AGENT_LAUNCH
}

IntegrationFailureClass: "IntegrationFailureClass <<enumeration>>" {
  shape: class
  EXPECTED_TASK_FAILURE
  INTERNAL_ERROR
}

IntegrationError: "IntegrationError <<exception>>" {
  shape: class
  boundary: IntegrationBoundary
  failure_class: IntegrationFailureClass
}

ExpectedTaskFailureError: "ExpectedTaskFailureError <<exception>>" {
  shape: class
}

InternalIntegrationError: "InternalIntegrationError <<exception>>" {
  shape: class
}

WorkspaceIntegrationError: "WorkspaceIntegrationError <<exception>>" {
  shape: class
}

SignalIntegrationError: "SignalIntegrationError <<exception>>" {
  shape: class
}

PullRequestIntegrationError: "PullRequestIntegrationError <<exception>>" {
  shape: class
}

AgentLaunchIntegrationError: "AgentLaunchIntegrationError <<exception>>" {
  shape: class
}

error_functions: "error_functions <<module>>" {
  shape: class
  module_path: errors
  +classify_integration_error(exc): IntegrationFailureClass
}

# Relationships
ExpectedTaskFailureError -> IntegrationError: { class: inheritance }
InternalIntegrationError -> IntegrationError: { class: inheritance }
WorkspaceIntegrationError -> InternalIntegrationError: { class: inheritance }
SignalIntegrationError -> InternalIntegrationError: { class: inheritance }
PullRequestIntegrationError -> InternalIntegrationError: { class: inheritance }
AgentLaunchIntegrationError -> InternalIntegrationError: { class: inheritance }
IntegrationError -> IntegrationBoundary: boundary { class: composition }
IntegrationError -> IntegrationFailureClass: failure_class { class: composition }
error_functions -> IntegrationFailureClass: returns { class: composition }
