direction: down

classes: {
  composition: {
    style.stroke: "#333333"
  }
  dependency: {
    style.stroke-dash: 3
  }
  inheritance: {
    target-arrowhead.shape: triangle
    style.stroke: "#333333"
  }
  implementation: {
    style.stroke-dash: 3
    target-arrowhead.shape: triangle
  }
}

AgentRole: "AgentRole <<enumeration>>" {
  shape: class
  SPEC_WRITER
  TEST_WRITER
  TEST_REVIEWER
  IMPLEMENTER
  GENERIC
}

AgentFramework: "AgentFramework <<enumeration>>" {
  shape: class
  CLAUDE_CODE
}

AgentVerbosity: "AgentVerbosity <<enumeration>>" {
  shape: class
  NONE
  STANDARD
  DETAILED
  EDUCATIONAL
}

TaskPaths: "TaskPaths <<frozen dataclass>>" {
  shape: class
  src: "tuple[Path, ...]"
  test: "tuple[Path, ...]"
  spec: "Path | None"
}

AgentConfig: "AgentConfig <<frozen dataclass>>" {
  shape: class
  framework: AgentFramework
  model: "str | None"
  adr_verbosity: AgentVerbosity
  environment: AgentEnvironment
}

ReviewConfig: "ReviewConfig <<frozen dataclass>>" {
  shape: class
  agent: AgentConfig
  review_on_attempt: int
}

Task: "Task <<frozen dataclass>>" {
  shape: class
  id: str
  role: AgentRole
  description: "str | None"
  paths: TaskPaths
  dependencies: "tuple[str, ...]"
  completion_gate: "str | None"
  max_gate_attempts: "int | None"
  primary_agent: AgentConfig
  review: "ReviewConfig | None"
  workstream_id: str
}

# Relationships
Task -> AgentRole: role { class: composition }
Task -> TaskPaths: paths { class: composition }
Task -> AgentConfig: primary_agent { class: composition }
Task -> ReviewConfig: review (optional) { class: composition }
AgentConfig -> AgentFramework: framework { class: composition }
AgentConfig -> AgentVerbosity: adr_verbosity { class: composition }
ReviewConfig -> AgentConfig: agent { class: composition }
