direction: down

classes: {
  composition: {
    style.stroke: "#333333"
  }
  dependency: {
    style.stroke-dash: 3
  }
  inheritance: {
    target-arrowhead.shape: triangle
    style.stroke: "#333333"
  }
  implementation: {
    style.stroke-dash: 3
    target-arrowhead.shape: triangle
  }
}

agent_core_pkg: "core/" {
  AgentAddress: "AgentAddress <<abstract>>" {
    shape: class
    +label(): str
  }

  Agent: "Agent <<abstract>>" {
    shape: class
    +send_kickoff(instructions_path): void
    +address(): AgentAddress
  }
}

agent_impl_pkg: "implementations/" {
  TmuxAddress: "TmuxAddress <<frozen dataclass>>" {
    shape: class
    session: str
    pane_id: str
    +label(): str
  }

  TmuxAgent: "TmuxAgent <<mutable dataclass>>" {
    shape: class
    -_address: TmuxAddress
    +address(): TmuxAddress
    +from_config(config, task_id, worktree_path, signal_dir): TmuxAgent
    +send_kickoff(instructions_path): void
  }
}

# Relationships
agent_impl_pkg.TmuxAddress -> agent_core_pkg.AgentAddress: { class: inheritance }
agent_impl_pkg.TmuxAgent -> agent_core_pkg.Agent: { class: inheritance }
agent_impl_pkg.TmuxAgent -> agent_impl_pkg.TmuxAddress: _address { class: composition }
agent_core_pkg.Agent -> agent_core_pkg.AgentAddress: address { class: composition }
