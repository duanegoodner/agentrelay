direction: down

classes: {
  composition: {
    style.stroke: "#333333"
  }
  dependency: {
    style.stroke-dash: 3
  }
  inheritance: {
    target-arrowhead.shape: triangle
    style.stroke: "#333333"
  }
  implementation: {
    style.stroke-dash: 3
    target-arrowhead.shape: triangle
  }
}

TaskRuntimeBuilder: "TaskRuntimeBuilder" {
  shape: class
  +from_graph(graph): "dict[str, TaskRuntime]"
}

TaskStatus: "TaskStatus <<enumeration>>" {
  shape: class
  PENDING
  RUNNING
  PR_CREATED
  PR_MERGED
  FAILED
}

TaskState: "TaskState <<mutable dataclass>>" {
  shape: class
  status: TaskStatus
  worktree_path: "Path | None"
  branch_name: "str | None"
  signal_dir: "Path | None"
  error: "str | None"
  attempt_num: int
  integration_branch: "str | None"
  workstream_worktree_path: "Path | None"
}

TaskArtifacts: "TaskArtifacts <<mutable dataclass>>" {
  shape: class
  pr_url: "str | None"
  concerns: "list[str]"
  agent_address: "AgentAddress | None"
}

TaskRuntime: "TaskRuntime <<mutable dataclass>>" {
  shape: class
  task: Task
  state: TaskState
  artifacts: TaskArtifacts
  +prepare_for_attempt(attempt_num): void
  +mark_failed(error): void
  +reset_for_retry(): void
  +mark_pending(): void
}

TaskStateView: "TaskStateView <<protocol>>" {
  shape: class
  +status(): TaskStatus
  +worktree_path(): "Path | None"
  +branch_name(): "str | None"
  +signal_dir(): "Path | None"
  +error(): "str | None"
  +attempt_num(): int
  +integration_branch(): "str | None"
  +workstream_worktree_path(): "Path | None"
}

TaskArtifactsView: "TaskArtifactsView <<protocol>>" {
  shape: class
  +pr_url(): "str | None"
  +concerns(): "Sequence[str]"
  +agent_address(): "AgentAddress | None"
}

TaskRuntimeView: "TaskRuntimeView <<protocol>>" {
  shape: class
  +task(): Task
  +state(): TaskStateView
  +artifacts(): TaskArtifactsView
}

# Relationships
TaskRuntimeBuilder -> TaskRuntime: builds { class: composition }
TaskState -> TaskStatus: status { class: composition }
TaskRuntime -> TaskState: state { class: composition }
TaskRuntime -> TaskArtifacts: artifacts { class: composition }
TaskState -> TaskStateView: satisfies { class: implementation }
TaskArtifacts -> TaskArtifactsView: satisfies { class: implementation }
TaskRuntime -> TaskRuntimeView: satisfies { class: implementation }
