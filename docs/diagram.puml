' ─────────────────────────────────────────────
'  workstream/ — workstream specs, runtime, and runner
' ─────────────────────────────────────────────
package "workstream/" as workstream_pkg {
    package "core/" as workstream_core_pkg {
        class WorkstreamSpec <<frozen dataclass>> {
            id : str
            parent_workstream_id : str | None
            base_branch : str
            merge_target_branch : str
        }

        class WorkstreamRuntimeBuilder {
            +{static} from_graph(graph) : dict[str, WorkstreamRuntime]
        }

        enum WorkstreamStatus <<enumeration>> {
            PENDING
            ACTIVE
            MERGED
            FAILED
        }

        class WorkstreamState <<mutable dataclass>> {
            status : WorkstreamStatus
            worktree_path : Path | None
            branch_name : str | None
            error : str | None
            active_task_id : str | None
        }

        class WorkstreamArtifacts <<mutable dataclass>> {
            merge_pr_url : str | None
            concerns : list[str]
        }

        class WorkstreamRuntime <<mutable dataclass>> {
            spec : WorkstreamSpec
            state : WorkstreamState
            artifacts : WorkstreamArtifacts
            +activate(task_id) : void
            +deactivate() : void
            +mark_failed(error) : void
            +mark_merged() : void
        }

        interface WorkstreamStateView <<protocol>> {
            +status() : WorkstreamStatus
            +worktree_path() : Path | None
            +branch_name() : str | None
            +error() : str | None
            +active_task_id() : str | None
        }

        interface WorkstreamArtifactsView <<protocol>> {
            +merge_pr_url() : str | None
            +concerns() : Sequence[str]
        }

        interface WorkstreamRuntimeView <<protocol>> {
            +spec() : WorkstreamSpec
            +state() : WorkstreamStateView
            +artifacts() : WorkstreamArtifactsView
        }

        interface WorkstreamPreparer <<protocol>> {
            +prepare_workstream(workstream_runtime) : void
        }

        interface WorkstreamMerger <<protocol>> {
            +merge_workstream(workstream_runtime) : void
        }

        interface WorkstreamTeardown <<protocol>> {
            +teardown_workstream(workstream_runtime) : void
        }

        class WorkstreamRunnerIO <<frozen dataclass>> {
            preparer : WorkstreamPreparer
            merger : WorkstreamMerger
            teardown_handler : WorkstreamTeardown
        }

        class WorkstreamRunResult <<frozen dataclass>> {
            workstream_id : str
            status : WorkstreamStatus
            error : str | None
        }

        class WorkstreamRunner <<mutable dataclass>> {
            io : WorkstreamRunnerIO
            __
            +prepare(workstream_runtime) : void
            +merge(workstream_runtime) : WorkstreamRunResult
            +teardown(workstream_runtime) : void
        }
    }

    package "implementations/" as workstream_impl_pkg {
    }
}

' ─────────────────────────────────────────────
'  task_graph/ — DAG structure and queries
' ─────────────────────────────────────────────
package "task_graph/" as task_graph_pkg {
    class TaskGraph <<frozen dataclass>> {
        name : str | None
        max_workstream_depth : int
        __
        +task(task_id) : Task
        +task_ids() : tuple[str, ...]
        +dependency_ids(task_id) : tuple[str, ...]
        +dependent_ids(task_id) : tuple[str, ...]
        +roots() : tuple[str, ...]
        +leaves() : tuple[str, ...]
        +topological_order() : tuple[str, ...]
        +ready_ids(completed_ids, running_ids) : tuple[str, ...]
        +workstream_ids() : tuple[str, ...]
        +workstream(workstream_id) : WorkstreamSpec
        +tasks_in_workstream(workstream_id) : tuple[str, ...]
        +child_workstream_ids(workstream_id) : tuple[str, ...]
    }

    class _validation <<module>> {
        module_path : task_graph._validation
        __
        +{static} normalize_workstreams(workstreams_by_id) : dict[str, WorkstreamSpec]
        +{static} validate_task_workstream_ids(tasks_by_id, workstreams_by_id) : void
        +{static} validate_workstream_parent_ids_exist(workstreams_by_id) : void
        +{static} validate_workstream_hierarchy_acyclic(workstreams_by_id) : void
        +{static} validate_workstream_max_depth(workstreams_by_id, max_depth) : void
        +{static} validate_dependencies_exist(tasks_by_id, dependency_ids) : void
        +{static} validate_known_ids(ids, tasks_by_id, source_name) : void
    }

    class _indexing <<module>> {
        module_path : task_graph._indexing
        __
        +{static} build_dependency_ids(tasks_by_id) : dict[str, tuple[str, ...]]
        +{static} build_dependent_ids(tasks_by_id, dependency_ids) : dict[str, tuple[str, ...]]
        +{static} topological_order_or_raise(dependency_ids, dependent_ids) : tuple[str, ...]
        +{static} build_task_ids_by_workstream(tasks_by_id, topological_order, workstreams_by_id) : dict[str, tuple[str, ...]]
        +{static} build_child_workstream_ids(workstreams_by_id) : dict[str, tuple[str, ...]]
    }

    class TaskGraphBuilder {
        +{static} from_yaml(path) : TaskGraph
        +{static} from_dict(data) : TaskGraph
    }
}

' ─────────────────────────────────────────────
'  task_runtime/ — mutable execution state
' ─────────────────────────────────────────────
package "task_runtime/" as task_runtime_pkg {
    class TaskRuntimeBuilder {
        +{static} from_graph(graph) : dict[str, TaskRuntime]
    }

    enum TaskStatus <<enumeration>> {
        PENDING
        RUNNING
        PR_CREATED
        PR_MERGED
        FAILED
    }

    class TaskState <<mutable dataclass>> {
        status : TaskStatus
        worktree_path : Path | None
        branch_name : str | None
        signal_dir : Path | None
        error : str | None
        attempt_num : int
    }

    class TaskArtifacts <<mutable dataclass>> {
        pr_url : str | None
        concerns : list[str]
        agent_address : AgentAddress | None
    }

    class TaskRuntime <<mutable dataclass>> {
        task : Task
        state : TaskState
        artifacts : TaskArtifacts
        +prepare_for_attempt(attempt_num) : void
        +mark_failed(error) : void
        +reset_for_retry() : void
        +mark_pending() : void
    }

    interface TaskStateView <<protocol>> {
        +status() : TaskStatus
        +worktree_path() : Path | None
        +branch_name() : str | None
        +signal_dir() : Path | None
        +error() : str | None
        +attempt_num() : int
    }

    interface TaskArtifactsView <<protocol>> {
        +pr_url() : str | None
        +concerns() : Sequence[str]
        +agent_address() : AgentAddress | None
    }

    interface TaskRuntimeView <<protocol>> {
        +task() : Task
        +state() : TaskStateView
        +artifacts() : TaskArtifactsView
    }
}

' ─────────────────────────────────────────────
'  task_runner/ — one-task lifecycle and I/O protocols
' ─────────────────────────────────────────────
package "task_runner/" as task_runner_pkg {
    package "core/" as task_runner_core_pkg {
        enum TearDownMode <<enumeration>> {
            ALWAYS
            NEVER
            ON_SUCCESS
        }

        class TaskCompletionSignal <<frozen dataclass>> {
            outcome : "done" | "failed"
            pr_url : str | None
            error : str | None
            concerns : tuple[str, ...]
        }

        interface TaskPreparer <<protocol>> {
            +prepare(runtime) : void
        }

        interface TaskLauncher <<protocol>> {
            +launch(runtime) : Agent
        }

        interface TaskKickoff <<protocol>> {
            +kickoff(runtime, agent) : void
        }

        interface TaskCompletionChecker <<protocol>> {
            +wait_for_completion(runtime) : TaskCompletionSignal
        }

        interface TaskMerger <<protocol>> {
            +merge_pr(runtime, pr_url) : void
        }

        interface TaskTeardown <<protocol>> {
            +teardown(runtime) : void
        }

        class TaskRunnerIO <<frozen dataclass>> {
            preparer : TaskPreparer
            launcher : TaskLauncher
            kickoff_sender : TaskKickoff
            completion_checker : TaskCompletionChecker
            merger : TaskMerger
            teardown_handler : TaskTeardown
        }

        class TaskRunResult <<frozen dataclass>> {
            task_id : str
            status : TaskStatus
            pr_url : str | None
            error : str | None
            failure_class : IntegrationFailureClass | None
        }

        class TaskRunner <<mutable dataclass>> {
            io : TaskRunnerIO
            __
            +run(runtime, teardown_mode) : TaskRunResult
        }
    }

    package "implementations/" as task_runner_impl_pkg {
        class WorktreeTaskPreparer <<dataclass>> {
            repo_path : Path
            graph_name : str
            integration_branch : str
            workstream_worktree_path : Path
            dependency_descriptions : dict
            context_content : str | None
            +prepare(runtime) : void
        }

        class TmuxTaskLauncher <<dataclass>> {
            +launch(runtime) : Agent
        }

        class TmuxTaskKickoff <<dataclass>> {
            +kickoff(runtime, agent) : void
        }

        class SignalCompletionChecker <<dataclass>> {
            poll_interval : float
            +wait_for_completion(runtime) : TaskCompletionSignal
        }

        class GhTaskMerger <<dataclass>> {
            repo_path : Path
            integration_branch : str
            +merge_pr(runtime, pr_url) : void
        }

        class WorktreeTaskTeardown <<dataclass>> {
            repo_path : Path
            keep_panes : bool
            +teardown(runtime) : void
        }
    }
}

