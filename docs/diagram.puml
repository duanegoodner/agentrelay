' ═════════════════════════════════════════════
'  Relationships
' ═════════════════════════════════════════════

' --- task.py internal ---
Task --> AgentRole : role
Task --> TaskPaths : paths
Task --> AgentConfig : primary_agent
Task --> ReviewConfig : review (optional)
Task ..> WorkstreamSpec : workstream_id (ref)
AgentConfig --> AgentFramework : framework
AgentConfig --> AgentVerbosity : adr_verbosity
ReviewConfig --> AgentConfig : agent

' --- environments ---
AgentConfig --> AgentEnvironment : environment
TmuxEnvironment ..|> AgentEnvironment

' --- agent ---
TmuxAddress --|> AgentAddress
TmuxAgent --|> Agent
TmuxAgent --> TmuxAddress : _address
Agent --> AgentAddress : address

' --- workspace ---
WorkspaceRef --> LocalWorkspaceRef : alias (extend to union for additional backends)

' --- task_graph ---
TaskGraph --> Task : contains
TaskGraph --> WorkstreamSpec : contains
TaskGraph ..> _validation : uses
TaskGraph ..> _indexing : uses
TaskGraphBuilder --> TaskGraph : builds

' --- builders ---
TaskRuntimeBuilder --> TaskGraph : reads
TaskRuntimeBuilder --> TaskRuntime : builds
WorkstreamRuntimeBuilder --> TaskGraph : reads
WorkstreamRuntimeBuilder --> WorkstreamRuntime : builds

' --- task_runner ---
TaskRunner --> TaskRunnerIO : uses
TaskRunnerIO --> TaskPreparer : preparer
TaskRunnerIO --> TaskLauncher : launcher
TaskRunnerIO --> TaskKickoff : kickoff_sender
TaskRunnerIO --> TaskCompletionChecker : completion_checker
TaskRunnerIO --> TaskMerger : merger
TaskRunnerIO --> TaskTeardown : teardown_handler
TaskRunner --> TaskRuntime : mutates
TaskRunner --> TaskRunResult : returns
TaskRunner --> TearDownMode : teardown policy
TaskCompletionChecker --> TaskCompletionSignal : returns
TaskLauncher --> Agent : launches
TaskRunResult --> TaskStatus : status
TaskRunResult --> IntegrationFailureClass : failure_class (optional)

' --- task_runtime internal ---
TaskState --> TaskStatus : status
TaskRuntime --> Task : task
TaskRuntime --> TaskState : state
TaskRuntime --> TaskArtifacts : artifacts
TaskArtifacts --> AgentAddress : agent_address (optional)
TaskState ..|> TaskStateView : satisfies
TaskArtifacts ..|> TaskArtifactsView : satisfies
TaskRuntime ..|> TaskRuntimeView : satisfies

' --- workstream internal ---
WorkstreamState --> WorkstreamStatus : status
WorkstreamRuntime --> WorkstreamSpec : spec
WorkstreamRuntime --> WorkstreamState : state
WorkstreamRuntime --> WorkstreamArtifacts : artifacts
WorkstreamState ..|> WorkstreamStateView : satisfies
WorkstreamArtifacts ..|> WorkstreamArtifactsView : satisfies
WorkstreamRuntime ..|> WorkstreamRuntimeView : satisfies

' --- workstream runner ---
WorkstreamRunner --> WorkstreamRunnerIO : uses
WorkstreamRunnerIO --> WorkstreamPreparer : preparer
WorkstreamRunnerIO --> WorkstreamMerger : merger
WorkstreamRunnerIO --> WorkstreamTeardown : teardown_handler
WorkstreamRunner --> WorkstreamRuntime : mutates
WorkstreamRunner --> WorkstreamRunResult : returns
WorkstreamRunResult --> WorkstreamStatus : status

' --- orchestrator ---
Orchestrator --> TaskGraph : reads
Orchestrator --> TaskRunner : delegates task runs
Orchestrator --> OrchestratorConfig : uses
Orchestrator --> OrchestratorResult : returns
OrchestratorResult --> OrchestratorOutcome : outcome
OrchestratorResult --> OrchestratorEvent : events
OrchestratorEvent --> TaskOutcomeClass : classification
OrchestratorConfig --> TearDownMode : teardown policy
Orchestrator --> OrchestratorListener : listener (optional)
OrchestratorListener --> OrchestratorEvent : receives
Orchestrator --> TaskRuntime : mutates
Orchestrator --> WorkstreamRuntime : mutates

' --- errors ---
ExpectedTaskFailureError --|> IntegrationError
InternalIntegrationError --|> IntegrationError
WorkspaceIntegrationError --|> InternalIntegrationError
SignalIntegrationError --|> InternalIntegrationError
PullRequestIntegrationError --|> InternalIntegrationError
AgentLaunchIntegrationError --|> InternalIntegrationError
IntegrationError --> IntegrationBoundary : boundary
IntegrationError --> IntegrationFailureClass : failure_class
error_functions --> IntegrationFailureClass : returns

' --- agent_comm_protocol ---
TaskManifest --> DependencyInfo : dependencies
TaskManifest --> AgentRole : role
WorkflowPolicies --> CommitPolicy : commit_policy (optional)
WorkflowPolicies --> PrPolicy : pr_policy (optional)
WorkflowPolicies --> CompletionGatePolicy : completion_gate (optional)
WorkflowPolicies --> ReviewPolicy : review (optional)
WorkflowPolicies --> AdrPolicy : adr (optional)
WorkflowPolicies --> VerificationPolicy : verification (optional)
CommitPolicy --> WorkflowAction : action
PrPolicy --> WorkflowAction : action
PrPolicy --> PrBodySection : body_sections
AdrPolicy --> AgentVerbosity : verbosity
manifest_functions --> Task : reads
manifest_functions --> TaskManifest : builds
policies_functions --> Task : reads
policies_functions --> WorkflowPolicies : builds
templates_functions --> AgentRole : reads
templates_functions --> TaskManifest : reads

' --- task_runner implementations ---
WorktreeTaskPreparer ..|> TaskPreparer : satisfies
TmuxTaskLauncher ..|> TaskLauncher : satisfies
TmuxTaskKickoff ..|> TaskKickoff : satisfies
SignalCompletionChecker ..|> TaskCompletionChecker : satisfies
GhTaskMerger ..|> TaskMerger : satisfies
WorktreeTaskTeardown ..|> TaskTeardown : satisfies
WorktreeTaskPreparer ..> git : uses
WorktreeTaskPreparer ..> signals : uses
WorktreeTaskPreparer ..> manifest_functions : uses
WorktreeTaskPreparer ..> policies_functions : uses
WorktreeTaskPreparer ..> templates_functions : uses
TmuxTaskLauncher ..> TmuxAgent : uses
SignalCompletionChecker ..> signals : uses
GhTaskMerger ..> gh : uses
GhTaskMerger ..> git : uses
WorktreeTaskTeardown ..> tmux : uses
WorktreeTaskTeardown ..> git : uses

' --- spec ---
PythonStubSpec ..|> SpecRepresentation : satisfies

