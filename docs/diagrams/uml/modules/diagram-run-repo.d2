direction: down
**.style.font-size: 50
*.style.font-size: 100

classes: {
  composition: {
    # NOTE: source-arrowhead.shape: diamond doesn't propagate via classes (D2 limitation)
    style.stroke: "#333333"
    style.stroke-width: 12
    style.font-size: 55
  }
  dependency: {
    target-arrowhead: {
      shape: arrow
      style.filled: false
    }
    style.stroke-dash: 3
    style.stroke-width: 12
    style.font-size: 55
  }
  inheritance: {
    target-arrowhead: {
      shape: triangle
      style.filled: false
    }
    style.stroke: "#333333"
    style.stroke-width: 12
    style.font-size: 55
  }
  implementation: {
    target-arrowhead: {
      shape: triangle
      style.filled: false
    }
    style.stroke-dash: 3
    style.stroke-width: 12
    style.font-size: 55
  }
}

# ─────────────────────────────────────────────
#  run_repo.py — repo operations for run lifecycle
# ─────────────────────────────────────────────
run_repo_py: "run_repo.py" {
  RunRepoManager: "RunRepoManager <<protocol>>" {
    shape: class
    "+current_head()": str
    "+reset_stale_worktree_branches(graph, frozen_task_ids)": void
  }

  GitRunRepoManager: "GitRunRepoManager" {
    shape: class
    repo_path: Path
    graph_name: str
    "+current_head()": str
    "+reset_stale_worktree_branches(graph, frozen_task_ids)": void
  }
}


# ─── External dependencies ───

ops_pkg: "ops/" {
  style.opacity: 0.5
  git: "git <<module>>" { shape: class }
}

run_graph_py: "run_graph.py" {
  style.opacity: 0.5
  run_graph_functions: "run_graph <<module>>" { shape: class }
}


# ─── Relationships ───

run_graph_py.run_graph_functions -> run_repo_py.RunRepoManager: "current_head, reset branches" { class: dependency }
run_repo_py.GitRunRepoManager -> run_repo_py.RunRepoManager: satisfies { class: implementation }
run_repo_py.GitRunRepoManager -> ops_pkg.git: uses { class: dependency }
