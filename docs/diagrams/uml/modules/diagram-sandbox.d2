direction: down
**.style.font-size: 50
*.style.font-size: 100

classes: {
  composition: {
    # NOTE: source-arrowhead.shape: diamond doesn't propagate via classes (D2 limitation)
    style.stroke: "#333333"
    style.stroke-width: 12
    style.font-size: 55
  }
  dependency: {
    target-arrowhead: {
      shape: arrow
      style.filled: false
    }
    style.stroke-dash: 3
    style.stroke-width: 12
    style.font-size: 55
  }
  inheritance: {
    target-arrowhead: {
      shape: triangle
      style.filled: false
    }
    style.stroke: "#333333"
    style.stroke-width: 12
    style.font-size: 55
  }
  implementation: {
    target-arrowhead: {
      shape: triangle
      style.filled: false
    }
    style.stroke-dash: 3
    style.stroke-width: 12
    style.font-size: 55
  }
}

# ─────────────────────────────────────────────
#  sandbox/ — sandbox configuration and protocols
# ─────────────────────────────────────────────
sandbox_pkg: "sandbox/" {
  sandbox_core_pkg: "core/" {
    SandboxType: "SandboxType <<enumeration>>" {
      shape: class
      NONE
      OCI
    }

    ContainerRuntime: "ContainerRuntime <<enumeration>>" {
      shape: class
      DOCKER
      PODMAN
    }

    TokenTier: "TokenTier <<enumeration>>" {
      shape: class
      READ_ONLY
      STANDARD
      ELEVATED
    }

    CredentialType: "CredentialType <<enumeration>>" {
      shape: class
      API_KEY
      OAUTH
    }

    AnthropicCredential: "AnthropicCredential <<frozen dataclass>>" {
      shape: class
      name: str
      credential_type: CredentialType
      api_key: "str | None"
      oauth_path: "Path | None"
    }

    IsolationConfig: "IsolationConfig <<frozen dataclass>>" {
      shape: class
      sandbox_type: SandboxType
      token_tier: TokenTier
      image: "str | None"
      runtime: "ContainerRuntime | None"
    }

    SandboxContext: "SandboxContext <<frozen dataclass>>" {
      shape: class
      worktree_path: Path
      signal_dir: Path
      repo_path: Path
      task_id: str
      graph_name: str
      env_vars: "dict[str, str]"
    }

    AgentSandbox: "AgentSandbox <<protocol>>" {
      shape: class
      "+wrap_command(cmd, context)": str
      "+setup(context)": void
      "+teardown(context)": void
    }

    AgentFrameworkAdapter: "AgentFrameworkAdapter <<protocol>>" {
      shape: class
      "+build_command(config, signal_dir)": str
    }

    CredentialProvider: "CredentialProvider <<protocol>>" {
      shape: class
      "+resolve(tier)": "dict[str, str]"
    }
  }

  sandbox_impl_pkg: "implementations/" {
    NullSandbox: "NullSandbox" {
      shape: class
      "+wrap_command(cmd, context)": str
      "+setup(context)": void
      "+teardown(context)": void
    }

    OciSandbox: "OciSandbox" {
      shape: class
      "-_anthropic_credential": "AnthropicCredential | None"
      "+wrap_command(cmd, context)": str
      "+setup(context)": void
      "+teardown(context)": void
    }

    ClaudeCodeAdapter: "ClaudeCodeAdapter" {
      shape: class
      "+build_command(config, signal_dir)": str
    }

    NullCredentialProvider: "NullCredentialProvider" {
      shape: class
      "+resolve(tier)": "dict[str, str]"
    }

    FileCredentialProvider: "FileCredentialProvider" {
      shape: class
      path: Path
      "+resolve(tier)": "dict[str, str]"
    }
  }
}


# ─── External dependencies ───

ops_pkg: "ops/" {
  style.opacity: 0.5
  docker: "docker <<module>>" { shape: class }
  git: "git <<module>>" { shape: class }
}

task_py: "task.py" {
  style.opacity: 0.5
  AgentConfig: "AgentConfig <<frozen dataclass>>" { shape: class }
  Task: "Task <<frozen dataclass>>" { shape: class }
}

workstream_pkg: "workstream/" {
  style.opacity: 0.5
  workstream_core_pkg: "core/" {
    WorkstreamSpec: "WorkstreamSpec <<frozen dataclass>>" { shape: class }
  }
}


# ─── Relationships ───

sandbox_pkg.sandbox_core_pkg.IsolationConfig -> sandbox_pkg.sandbox_core_pkg.SandboxType: sandbox_type { class: composition }
sandbox_pkg.sandbox_core_pkg.IsolationConfig -> sandbox_pkg.sandbox_core_pkg.TokenTier: token_tier { class: composition }
sandbox_pkg.sandbox_core_pkg.IsolationConfig -> sandbox_pkg.sandbox_core_pkg.ContainerRuntime: runtime { class: composition }
sandbox_pkg.sandbox_core_pkg.AgentSandbox -> sandbox_pkg.sandbox_core_pkg.SandboxContext: context { class: dependency }
sandbox_pkg.sandbox_impl_pkg.NullSandbox -> sandbox_pkg.sandbox_core_pkg.AgentSandbox: satisfies { class: implementation }
sandbox_pkg.sandbox_impl_pkg.OciSandbox -> sandbox_pkg.sandbox_core_pkg.AgentSandbox: satisfies { class: implementation }
sandbox_pkg.sandbox_impl_pkg.OciSandbox -> ops_pkg.docker: uses { class: dependency }
sandbox_pkg.sandbox_impl_pkg.OciSandbox -> ops_pkg.git: uses { class: dependency }
sandbox_pkg.sandbox_impl_pkg.OciSandbox -> sandbox_pkg.sandbox_core_pkg.AnthropicCredential: _anthropic_credential { class: composition }
sandbox_pkg.sandbox_core_pkg.AnthropicCredential -> sandbox_pkg.sandbox_core_pkg.CredentialType: credential_type { class: composition }
sandbox_pkg.sandbox_core_pkg.AgentFrameworkAdapter -> task_py.AgentConfig: config { class: dependency }
sandbox_pkg.sandbox_impl_pkg.ClaudeCodeAdapter -> sandbox_pkg.sandbox_core_pkg.AgentFrameworkAdapter: satisfies { class: implementation }
sandbox_pkg.sandbox_core_pkg.CredentialProvider -> sandbox_pkg.sandbox_core_pkg.TokenTier: tier { class: dependency }
sandbox_pkg.sandbox_impl_pkg.NullCredentialProvider -> sandbox_pkg.sandbox_core_pkg.CredentialProvider: satisfies { class: implementation }
sandbox_pkg.sandbox_impl_pkg.FileCredentialProvider -> sandbox_pkg.sandbox_core_pkg.CredentialProvider: satisfies { class: implementation }
task_py.AgentConfig -> sandbox_pkg.sandbox_core_pkg.IsolationConfig: "isolation (optional)" { class: composition }
task_py.Task -> sandbox_pkg.sandbox_core_pkg.IsolationConfig: "isolation (optional)" { class: composition }
workstream_pkg.workstream_core_pkg.WorkstreamSpec -> sandbox_pkg.sandbox_core_pkg.IsolationConfig: "isolation (optional)" { class: composition }
