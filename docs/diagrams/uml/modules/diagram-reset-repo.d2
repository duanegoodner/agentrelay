direction: down
**.style.font-size: 50
*.style.font-size: 100

classes: {
  composition: {
    # NOTE: source-arrowhead.shape: diamond doesn't propagate via classes (D2 limitation)
    style.stroke: "#333333"
    style.stroke-width: 12
    style.font-size: 55
  }
  dependency: {
    target-arrowhead: {
      shape: arrow
      style.filled: false
    }
    style.stroke-dash: 3
    style.stroke-width: 12
    style.font-size: 55
  }
  inheritance: {
    target-arrowhead: {
      shape: triangle
      style.filled: false
    }
    style.stroke: "#333333"
    style.stroke-width: 12
    style.font-size: 55
  }
  implementation: {
    target-arrowhead: {
      shape: triangle
      style.filled: false
    }
    style.stroke-dash: 3
    style.stroke-width: 12
    style.font-size: 55
  }
}

# ─────────────────────────────────────────────
#  reset_repo.py — RepoResetOps protocol + Git implementation
# ─────────────────────────────────────────────
reset_repo_py: "reset_repo.py" {
  RepoResetOps: "RepoResetOps <<protocol>>" {
    shape: class
    module_path: reset_repo
    "+branch_delete(branch)": void
    "+push_delete_branch(branch)": void
    "+update_local_ref(branch, target_sha)": void
    "+push_force_with_lease(branch)": void
    "+worktree_remove(worktree_path)": void
    "+worktree_prune()": void
    "+rev_parse(ref)": str
    "+checkout_in(worktree_path, branch)": void
    "+clean_in(worktree_path)": void
    "+current_branch_in(worktree_path)": "str | None"
  }
  GitRepoResetOps: "GitRepoResetOps" {
    shape: class
    module_path: reset_repo
  }
  GitRepoResetOps -> RepoResetOps: satisfies { class: implementation }
}


# ─── External dependencies ───

ops_pkg: "ops/" {
  style.opacity: 0.5
  git: "git <<module>>" { shape: class }
}

reset_ops_py: "reset_ops.py" {
  style.opacity: 0.5
  ResetOps: "ResetOps" { shape: class }
}


# ─── Relationships ───

reset_repo_py.GitRepoResetOps -> ops_pkg.git: "branch, worktree, push, ref ops" { class: dependency }
reset_ops_py.ResetOps -> reset_repo_py.RepoResetOps: "delegates git ops" { class: dependency }
