direction: right
**.style.font-size: 50
*.style.font-size: 100

classes: {
  composition: {
    # NOTE: source-arrowhead.shape: diamond doesn't propagate via classes (D2 limitation)
    style.stroke: "#333333"
    style.stroke-width: 12
    style.font-size: 55
  }
  dependency: {
    target-arrowhead: {
      shape: arrow
      style.filled: false
    }
    style.stroke-dash: 3
    style.stroke-width: 12
    style.font-size: 55
  }
  inheritance: {
    target-arrowhead: {
      shape: triangle
      style.filled: false
    }
    style.stroke: "#333333"
    style.stroke-width: 12
    style.font-size: 55
  }
  implementation: {
    target-arrowhead: {
      shape: triangle
      style.filled: false
    }
    style.stroke-dash: 3
    style.stroke-width: 12
    style.font-size: 55
  }
}

# ─────────────────────────────────────────────
#  agent_sdk/ — agent-side helpers
# ─────────────────────────────────────────────
agent_sdk_pkg: "agent_sdk/" {
  TaskHelper: "TaskHelper <<class>>" {
    shape: class
    signal_dir: Path
    task_id: str
    branch_name: str
    integration_branch: str
    +from_env(): TaskHelper
    +complete(title, body): void
    +complete_without_pr(): void
    +create_pr(title, body): str
    +mark_done(pr_url): void
    +mark_failed(reason): void
    +record_concern(concern): void
    +record_ops_concern(concern): void
    +write_summary(message): void
    +declare_output(path, action, category): void
  }

  cli: "cli <<module>>" {
    shape: class
    module_path: agent_sdk.cli
    "+complete()": void
    "+complete_no_pr()": void
    "+failed()": void
    "+concern()": void
    "+ops_concern()": void
    "+summary()": void
    "+declare()": void
  }

  OutputAction: "OutputAction <<enumeration>>" {
    shape: class
    CREATED
    MODIFIED
    DELETED
  }

  OutputEntry: "OutputEntry <<frozen dataclass>>" {
    shape: class
    path: str
    action: OutputAction
    category: str
  }

  OutputManifest: "OutputManifest <<dataclass>>" {
    shape: class
    schema_version: str
    files: "list[OutputEntry]"
  }
}


# ─── External dependencies ───

agent_comm_protocol_pkg: "agent_comm_protocol/" {
  style.opacity: 0.5
  TaskManifest: "TaskManifest <<frozen dataclass>>" { shape: class }
}

ops_pkg: "ops/" {
  style.opacity: 0.5
  gh: "gh <<module>>" { shape: class }
}

task_runner_pkg: "task_runner/" {
  style.opacity: 0.5
  task_runner_impl_pkg: "implementations/" {
    WorktreeTaskPreparer: "WorktreeTaskPreparer <<dataclass>>" { shape: class }
  }
}


# ─── Relationships ───

task_runner_pkg.task_runner_impl_pkg.WorktreeTaskPreparer -> agent_sdk_pkg.OutputManifest: "reads outputs.json" { class: dependency }
agent_sdk_pkg.TaskHelper -> agent_comm_protocol_pkg.TaskManifest: "reads manifest.json" { class: dependency }
agent_sdk_pkg.TaskHelper -> ops_pkg.gh: "creates PR" { class: dependency }
agent_sdk_pkg.cli -> agent_sdk_pkg.TaskHelper: delegates { class: dependency }
agent_sdk_pkg.TaskHelper -> agent_sdk_pkg.OutputManifest: "reads/writes outputs.json" { class: dependency }
agent_sdk_pkg.OutputManifest -> agent_sdk_pkg.OutputEntry: files { class: composition }
agent_sdk_pkg.OutputEntry -> agent_sdk_pkg.OutputAction: action { class: dependency }
