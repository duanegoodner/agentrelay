direction: down
**.style.font-size: 50
*.style.font-size: 100

classes: {
  composition: {
    # NOTE: source-arrowhead.shape: diamond doesn't propagate via classes (D2 limitation)
    style.stroke: "#333333"
    style.stroke-width: 12
    style.font-size: 55
  }
  dependency: {
    target-arrowhead: {
      shape: arrow
      style.filled: false
    }
    style.stroke-dash: 3
    style.stroke-width: 12
    style.font-size: 55
  }
  inheritance: {
    target-arrowhead: {
      shape: triangle
      style.filled: false
    }
    style.stroke: "#333333"
    style.stroke-width: 12
    style.font-size: 55
  }
  implementation: {
    target-arrowhead: {
      shape: triangle
      style.filled: false
    }
    style.stroke-dash: 3
    style.stroke-width: 12
    style.font-size: 55
  }
}

# ─────────────────────────────────────────────
#  reset_ops.py — ResetOps shared reset operations
# ─────────────────────────────────────────────
reset_ops_py: "reset_ops.py" {
  ResetOps: "ResetOps" {
    shape: class
    module_path: reset_ops
    "+reset_branch(branch, target_sha)": void
    "+reset_task_state(run_dir, task_id, graph_name)": "list[str]"
    "+reset_workstream_state(run_dir, ws_id, graph_name)": "list[str]"
    "+find_workstream_tip(run_dir, graph, ws_id)": "str | None"
    "+workstream_merge_order(run_dir, graph)": "list[str]"
    "+write_rollback_entry(ws_signal_dir, task_id, ...)": void
    "+rollback_workstream_advancement(ws_signal_dir)": "list[str]"
    "+for_repo(repo_path)": ResetOps
  }
}


# ─── External dependencies ───

reset_repo_py: "reset_repo.py" {
  style.opacity: 0.5
  RepoResetOps: "RepoResetOps <<protocol>>" { shape: class }
}

reset_task_py: "reset_task.py" {
  style.opacity: 0.5
  reset_task_functions: "reset_task <<module>>" { shape: class }
}

reset_to_py: "reset_to.py" {
  style.opacity: 0.5
  reset_to_functions: "reset_to <<module>>" { shape: class }
}

reset_workstream_py: "reset_workstream.py" {
  style.opacity: 0.5
  reset_workstream_functions: "reset_workstream <<module>>" { shape: class }
}

resolved_py: "resolved.py" {
  style.opacity: 0.5
  ResolvedWorkstream: "ResolvedWorkstream <<frozen dataclass>>" { shape: class }
}

task_graph_pkg: "task_graph/" {
  style.opacity: 0.5
  TaskGraph: "TaskGraph <<frozen dataclass>>" { shape: class }
}


# ─── Relationships ───

reset_ops_py.ResetOps -> reset_repo_py.RepoResetOps: "delegates git ops" { class: dependency }
reset_ops_py.ResetOps -> resolved_py.ResolvedWorkstream: "reads resolved.json" { class: dependency }
reset_ops_py.ResetOps -> task_graph_pkg.TaskGraph: "tasks_in_workstream, workstream_ids" { class: dependency }
reset_task_py.reset_task_functions -> reset_ops_py.ResetOps: "reset_task_state, find_workstream_tip, reset_branch, write_rollback_entry" { class: dependency }
reset_workstream_py.reset_workstream_functions -> reset_ops_py.ResetOps: "shared utilities" { class: dependency }
reset_to_py.reset_to_functions -> reset_ops_py.ResetOps: "shared utilities" { class: dependency }
