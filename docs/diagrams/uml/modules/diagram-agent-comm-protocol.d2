direction: right
**.style.font-size: 50
*.style.font-size: 100

classes: {
  composition: {
    # NOTE: source-arrowhead.shape: diamond doesn't propagate via classes (D2 limitation)
    style.stroke: "#333333"
    style.stroke-width: 12
    style.font-size: 55
  }
  dependency: {
    target-arrowhead: {
      shape: arrow
      style.filled: false
    }
    style.stroke-dash: 3
    style.stroke-width: 12
    style.font-size: 55
  }
  inheritance: {
    target-arrowhead: {
      shape: triangle
      style.filled: false
    }
    style.stroke: "#333333"
    style.stroke-width: 12
    style.font-size: 55
  }
  implementation: {
    target-arrowhead: {
      shape: triangle
      style.filled: false
    }
    style.stroke-dash: 3
    style.stroke-width: 12
    style.font-size: 55
  }
}

# ─────────────────────────────────────────────
#  agent_comm_protocol/ — agent communication protocol layers 1-3
# ─────────────────────────────────────────────
agent_comm_protocol_pkg: "agent_comm_protocol/" {
  TaskManifest: "TaskManifest <<frozen dataclass>>" {
    shape: class
    schema_version: str
    task_id: str
    role: AgentRole
    description: "str | None"
    src_paths: "tuple[Path, ...]"
    test_paths: "tuple[Path, ...]"
    spec_path: "Path | None"
    branch_name: str
    integration_branch: str
    attempt_num: int
    graph_name: "str | None"
    dependencies: "dict[str, DependencyInfo]"
    tools: "tuple[str, ...]"
  }

  DependencyInfo: "DependencyInfo <<frozen dataclass>>" {
    shape: class
    description: "str | None"
  }

  WorkflowPolicies: "WorkflowPolicies <<frozen dataclass>>" {
    shape: class
    schema_version: str
    commit_policy: "_CommitPolicy | None"
    pr_policy: "_PrPolicy | None"
    completion_gate: "_CompletionGatePolicy | None"
    review: "_ReviewPolicy | None"
    adr: "_AdrPolicy | None"
    verification: "_VerificationPolicy | None"
  }

  _WorkflowAction: "_WorkflowAction <<str>>" {
    shape: class
    COMMIT_AND_PUSH
    CREATE_PR
    SIGNAL_DONE
    SIGNAL_FAILED
    RUN_COMPLETION_GATE
    RECORD_CONCERN
    WRITE_ADR
    RUN_VERIFICATION
  }

  _PrBodySection: "_PrBodySection <<str>>" {
    shape: class
    SUMMARY
    FILES_CHANGED
  }

  _CommitPolicy: "_CommitPolicy <<frozen dataclass>>" {
    shape: class
    action: _WorkflowAction
  }

  _PrPolicy: "_PrPolicy <<frozen dataclass>>" {
    shape: class
    action: _WorkflowAction
    base_branch: str
    title_template: str
    body_sections: "tuple[_PrBodySection, ...]"
  }

  _CompletionGatePolicy: "_CompletionGatePolicy <<frozen dataclass>>" {
    shape: class
    command: str
    max_attempts: int
    output_file: str
  }

  _VerificationPolicy: "_VerificationPolicy <<frozen dataclass>>" {
    shape: class
    commands: "tuple[str, ...]"
  }

  _AdrPolicy: "_AdrPolicy <<frozen dataclass>>" {
    shape: class
    verbosity: AdrVerbosity
  }

  _ReviewPolicy: "_ReviewPolicy <<frozen dataclass>>" {
    shape: class
    model: "str | None"
    review_on_attempt: int
  }

  manifest_functions: "manifest_functions <<module>>" {
    shape: class
    module_path: agent_comm_protocol.manifest
    "+build_manifest(task, ..., tools)": TaskManifest
    "+manifest_to_dict(manifest)": dict
  }

  policies_functions: "policies_functions <<module>>" {
    shape: class
    module_path: agent_comm_protocol.policies
    +build_policies(task, integration_branch, default_max_gate_attempts): WorkflowPolicies
    +policies_to_dict(policies): dict
  }

  templates_functions: "templates_functions <<module>>" {
    shape: class
    module_path: agent_comm_protocol.templates
    +resolve_instructions(role, manifest, adapter_name, adr_verbosity): str
  }
}


# ─── External dependencies ───

agent_sdk_pkg: "agent_sdk/" {
  style.opacity: 0.5
  TaskHelper: "TaskHelper <<class>>" { shape: class }
}

task_py: "task.py" {
  style.opacity: 0.5
  AdrVerbosity: "AdrVerbosity <<enumeration>>" { shape: class }
  AgentRole: "AgentRole <<enumeration>>" { shape: class }
  Task: "Task <<frozen dataclass>>" { shape: class }
}

task_runner_pkg: "task_runner/" {
  style.opacity: 0.5
  task_runner_impl_pkg: "implementations/" {
    WorktreeTaskPreparer: "WorktreeTaskPreparer <<dataclass>>" { shape: class }
  }
}

tools_py: "tools.py" {
  style.opacity: 0.5
  tools_functions: "tools <<module>>" { shape: class }
}


# ─── Relationships ───

agent_comm_protocol_pkg.TaskManifest -> agent_comm_protocol_pkg.DependencyInfo: dependencies { class: composition }
agent_comm_protocol_pkg.TaskManifest -> task_py.AgentRole: role { class: composition }
agent_comm_protocol_pkg.WorkflowPolicies -> agent_comm_protocol_pkg._CommitPolicy: "commit_policy (optional)" { class: composition }
agent_comm_protocol_pkg.WorkflowPolicies -> agent_comm_protocol_pkg._PrPolicy: "pr_policy (optional)" { class: composition }
agent_comm_protocol_pkg.WorkflowPolicies -> agent_comm_protocol_pkg._CompletionGatePolicy: "completion_gate (optional)" { class: composition }
agent_comm_protocol_pkg.WorkflowPolicies -> agent_comm_protocol_pkg._ReviewPolicy: "review (optional)" { class: composition }
agent_comm_protocol_pkg.WorkflowPolicies -> agent_comm_protocol_pkg._AdrPolicy: "adr (optional)" { class: composition }
agent_comm_protocol_pkg.WorkflowPolicies -> agent_comm_protocol_pkg._VerificationPolicy: "verification (optional)" { class: composition }
agent_comm_protocol_pkg._CommitPolicy -> agent_comm_protocol_pkg._WorkflowAction: action { class: composition }
agent_comm_protocol_pkg._PrPolicy -> agent_comm_protocol_pkg._WorkflowAction: action { class: composition }
agent_comm_protocol_pkg._PrPolicy -> agent_comm_protocol_pkg._PrBodySection: body_sections { class: composition }
agent_comm_protocol_pkg._AdrPolicy -> task_py.AdrVerbosity: verbosity { class: composition }
agent_comm_protocol_pkg.manifest_functions -> task_py.Task: reads { class: dependency }
agent_comm_protocol_pkg.manifest_functions -> agent_comm_protocol_pkg.TaskManifest: builds { class: dependency }
agent_comm_protocol_pkg.policies_functions -> task_py.Task: reads { class: dependency }
agent_comm_protocol_pkg.policies_functions -> agent_comm_protocol_pkg.WorkflowPolicies: builds { class: dependency }
agent_comm_protocol_pkg.templates_functions -> task_py.AgentRole: reads { class: dependency }
agent_comm_protocol_pkg.templates_functions -> agent_comm_protocol_pkg.TaskManifest: reads { class: dependency }
task_runner_pkg.task_runner_impl_pkg.WorktreeTaskPreparer -> agent_comm_protocol_pkg.manifest_functions: uses { class: dependency }
task_runner_pkg.task_runner_impl_pkg.WorktreeTaskPreparer -> agent_comm_protocol_pkg.policies_functions: uses { class: dependency }
task_runner_pkg.task_runner_impl_pkg.WorktreeTaskPreparer -> agent_comm_protocol_pkg.templates_functions: uses { class: dependency }
agent_sdk_pkg.TaskHelper -> agent_comm_protocol_pkg.TaskManifest: "reads manifest.json" { class: dependency }
agent_comm_protocol_pkg.templates_functions -> tools_py.tools_functions: "tool_guidance()" { class: dependency }
