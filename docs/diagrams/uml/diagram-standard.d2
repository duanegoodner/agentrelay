# ═════════════════════════════════════════════
#  Relationships
# ═════════════════════════════════════════════

# --- task.py internal ---
task_py.Task -> task_py.AgentRole: role { class: composition }
task_py.Task -> task_py.TaskPaths: paths { class: composition }
task_py.Task -> task_py.AgentConfig: primary_agent { class: composition }
task_py.Task -> task_py.ReviewConfig: "review (optional)" { class: composition }
task_py.Task -> workstream_pkg.workstream_core_pkg.WorkstreamSpec: "workstream_id (ref)" { class: dependency }
task_py.AgentConfig -> task_py.AgentFramework: framework { class: composition }
task_py.AgentConfig -> task_py.AgentVerbosity: adr_verbosity { class: composition }
task_py.ReviewConfig -> task_py.AgentConfig: agent { class: composition }

# --- environments ---
task_py.AgentConfig -> environments_py.AgentEnvironment: environment { class: composition }
environments_py.TmuxEnvironment -> environments_py.AgentEnvironment { class: implementation }

# --- agent ---
agent_pkg.agent_impl_pkg -> agent_pkg.agent_core_pkg.AgentAddress { class: inheritance }
agent_pkg.agent_impl_pkg -> agent_pkg.agent_core_pkg.Agent { class: inheritance }
agent_pkg.agent_core_pkg.Agent -> agent_pkg.agent_core_pkg.AgentAddress: address { class: composition }


# --- task_graph ---
task_graph_pkg.TaskGraph -> task_py.Task: contains { class: composition }
task_graph_pkg.TaskGraph -> workstream_pkg.workstream_core_pkg.WorkstreamSpec: contains { class: composition }
task_graph_pkg.TaskGraphBuilder -> task_graph_pkg.TaskGraph: builds { class: dependency }

# --- builders (in orchestrator/) ---
orchestrator_pkg.TaskRuntimeBuilder -> task_graph_pkg.TaskGraph: reads { class: dependency }
orchestrator_pkg.TaskRuntimeBuilder -> task_runtime_pkg.TaskRuntime: builds { class: dependency }
orchestrator_pkg.WorkstreamRuntimeBuilder -> task_graph_pkg.TaskGraph: reads { class: dependency }
orchestrator_pkg.WorkstreamRuntimeBuilder -> workstream_pkg.workstream_core_pkg.WorkstreamRuntime: builds { class: dependency }

# --- task_runner ---
task_runner_pkg.task_runner_core_pkg.StandardTaskRunner -> task_runner_pkg.task_runner_core_pkg.TaskRunner: satisfies { class: implementation }
task_runner_pkg.task_runner_core_pkg.StandardTaskRunner -> task_runner_pkg.task_runner_core_pkg.StepDispatch: "6 fields" { class: composition }
task_runner_pkg.task_runner_core_pkg.StepDispatch -> task_runner_pkg.task_runner_core_pkg.TaskPreparer: resolves { class: dependency }
task_runner_pkg.task_runner_core_pkg.StepDispatch -> task_runner_pkg.task_runner_core_pkg.TaskLauncher: resolves { class: dependency }
task_runner_pkg.task_runner_core_pkg.StepDispatch -> task_runner_pkg.task_runner_core_pkg.TaskKickoff: resolves { class: dependency }
task_runner_pkg.task_runner_core_pkg.StepDispatch -> task_runner_pkg.task_runner_core_pkg.TaskCompletionChecker: resolves { class: dependency }
task_runner_pkg.task_runner_core_pkg.StepDispatch -> task_runner_pkg.task_runner_core_pkg.TaskMerger: resolves { class: dependency }
task_runner_pkg.task_runner_core_pkg.StepDispatch -> task_runner_pkg.task_runner_core_pkg.TaskTeardown: resolves { class: dependency }
task_runner_pkg.task_runner_core_pkg.StandardTaskRunner -> task_runtime_pkg.TaskRuntime: mutates { class: dependency }
task_runner_pkg.task_runner_core_pkg.StandardTaskRunner -> task_runner_pkg.task_runner_core_pkg.TaskRunResult: returns { class: dependency }
task_runner_pkg.task_runner_core_pkg.StandardTaskRunner -> task_runner_pkg.task_runner_core_pkg.TearDownMode: "teardown policy" { class: composition }
task_runner_pkg.task_runner_core_pkg.TaskCompletionChecker -> task_runner_pkg.task_runner_core_pkg.TaskCompletionSignal: returns { class: dependency }
task_runner_pkg.task_runner_core_pkg.TaskLauncher -> agent_pkg.agent_core_pkg.Agent: launches { class: dependency }
task_runner_pkg.task_runner_core_pkg.TaskRunResult -> task_runtime_pkg.TaskStatus: status { class: composition }
task_runner_pkg.task_runner_core_pkg.TaskRunResult -> errors_pkg.IntegrationFailureClass: "failure_class (optional)" { class: composition }
orchestrator_pkg.builders -> task_runner_pkg.task_runner_core_pkg.StandardTaskRunner: builds { class: dependency }
