direction: right
**.style.font-size: 50
*.style.font-size: 100

classes: {
  composition: {
    # NOTE: source-arrowhead.shape: diamond doesn't propagate via classes (D2 limitation)
    style.stroke: "#333333"
    style.stroke-width: 12
    style.font-size: 55
  }
  dependency: {
    target-arrowhead: {
      shape: arrow
      style.filled: false
    }
    style.stroke-dash: 3
    style.stroke-width: 12
    style.font-size: 55
  }
  inheritance: {
    target-arrowhead: {
      shape: triangle
      style.filled: false
    }
    style.stroke: "#333333"
    style.stroke-width: 12
    style.font-size: 55
  }
  implementation: {
    target-arrowhead: {
      shape: triangle
      style.filled: false
    }
    style.stroke-dash: 3
    style.stroke-width: 12
    style.font-size: 55
  }
}

# ─────────────────────────────────────────────
#  task.py — immutable task specifications
# ─────────────────────────────────────────────
task_py: "task.py" {
  AgentRole: "AgentRole <<enumeration>>" {
    shape: class
    SPEC_WRITER
    TEST_WRITER
    TEST_REVIEWER
    IMPLEMENTER
    GENERIC
  }

  AgentFramework: "AgentFramework <<enumeration>>" {
    shape: class
    CLAUDE_CODE
  }

  AgentVerbosity: "AgentVerbosity <<enumeration>>" {
    shape: class
    NONE
    STANDARD
    DETAILED
    EDUCATIONAL
  }

  TaskPaths: "TaskPaths <<frozen dataclass>>" {
    shape: class
    src: "tuple[Path, ...]"
    test: "tuple[Path, ...]"
    spec: "Path | None"
  }

  AgentConfig: "AgentConfig <<frozen dataclass>>" {
    shape: class
    framework: AgentFramework
    model: "str | None"
    adr_verbosity: AgentVerbosity
    environment: AgentEnvironment
  }

  ReviewConfig: "ReviewConfig <<frozen dataclass>>" {
    shape: class
    agent: AgentConfig
    review_on_attempt: int
  }

  Task: "Task <<frozen dataclass>>" {
    shape: class
    id: str
    role: AgentRole
    description: "str | None"
    paths: TaskPaths
    dependencies: "tuple[str, ...]"
    completion_gate: "str | None"
    max_gate_attempts: "int | None"
    primary_agent: AgentConfig
    review: "ReviewConfig | None"
    workstream_id: str
  }
}

# ─────────────────────────────────────────────
#  environments.py — execution environments
# ─────────────────────────────────────────────
environments_py: "environments.py" {
  AgentEnvironment: "AgentEnvironment <<type alias>>" {
    shape: class
  }

  TmuxEnvironment: "TmuxEnvironment <<frozen dataclass>>" {
    shape: class
    session: str
  }
}

# ─────────────────────────────────────────────
#  agent/ — agent abstractions
# ─────────────────────────────────────────────
agent_pkg: "agent/" {
  agent_core_pkg: "core/" {
    AgentAddress: "AgentAddress <<abstract>>" {
      shape: class
      +label(): str
      +teardown(signal_dir, keep_panes): void
    }

    Agent: "Agent <<abstract>>" {
      shape: class
      +send_kickoff(instructions_path): void
      +address(): AgentAddress
    }
  }

  agent_impl_pkg: "implementations/" {
    "(2 classes hidden)"
  }
}


# ─────────────────────────────────────────────
#  workstream/ — workstream specs, runtime, and runner
# ─────────────────────────────────────────────
workstream_pkg: "workstream/" {
  workstream_core_pkg: "core/" {
    WorkstreamSpec: "WorkstreamSpec <<frozen dataclass>>" {
      shape: class
      id: str
      parent_workstream_id: "str | None"
      base_branch: str
      merge_target_branch: str
    }

    WorkstreamStatus: "WorkstreamStatus <<enumeration>>" {
      shape: class
      PENDING
      ACTIVE
      MERGE_READY
      PR_CREATED
      MERGED
      FAILED
    }

    WorkstreamState: "WorkstreamState <<mutable dataclass>>" {
      shape: class
      signal_dir: "Path | None"
      worktree_path: "Path | None"
      branch_name: "str | None"
      error: "str | None"
    }

    WorkstreamArtifacts: "WorkstreamArtifacts <<mutable dataclass>>" {
      shape: class
      merge_pr_url: "str | None"
      concerns: "list[str]"
      task_summaries: "list[TaskSummary]"
    }

    TaskSummary: "TaskSummary <<frozen dataclass>>" {
      shape: class
      task_id: str
      description: "str | None"
      pr_url: "str | None"
      concerns: "tuple[str, ...]"
      ops_concerns: "tuple[str, ...]"
    }

    WorkstreamRuntime: "WorkstreamRuntime <<mutable dataclass>>" {
      shape: class
      spec: WorkstreamSpec
      state: WorkstreamState
      artifacts: WorkstreamArtifacts
      +status(): WorkstreamStatus
      +mark_pending(): void
      +mark_active(): void
      +mark_merge_ready(): void
      +mark_pr_created(pr_url): void
      +mark_merged(): void
      +mark_failed(error): void
    }

    WorkstreamPreparer: "WorkstreamPreparer <<protocol>>" {
      shape: class
      +prepare_workstream(workstream_runtime): void
    }

    WorkstreamIntegrator: "WorkstreamIntegrator <<protocol>>" {
      shape: class
      +create_integration_pr(workstream_runtime): void
    }

    WorkstreamTeardown: "WorkstreamTeardown <<protocol>>" {
      shape: class
      +teardown_workstream(workstream_runtime): void
    }

    WorkstreamRunResult: "WorkstreamRunResult <<frozen dataclass>>" {
      shape: class
      workstream_id: str
      status: WorkstreamStatus
      error: "str | None"
    }

    WorkstreamRunner: "WorkstreamRunner <<protocol>>" {
      shape: class
      +prepare(workstream_runtime): void
      +integrate(workstream_runtime): WorkstreamRunResult
      +teardown(workstream_runtime): void
    }

    StandardWorkstreamRunner: "StandardWorkstreamRunner <<mutable dataclass>>" {
      shape: class
      +prepare(workstream_runtime): void
      +integrate(workstream_runtime): WorkstreamRunResult
      +teardown(workstream_runtime): void
    }
  }

  workstream_impl_pkg: "implementations/" {
    "(3 classes hidden)"
  }
}

# ─────────────────────────────────────────────
#  task_graph/ — DAG structure and queries
# ─────────────────────────────────────────────
task_graph_pkg: "task_graph/" {
  TaskGraph: "TaskGraph <<frozen dataclass>>" {
    shape: class
    name: "str | None"
    max_workstream_depth: int
    +task(task_id): Task
    +task_ids(): "tuple[str, ...]"
    +dependency_ids(task_id): "tuple[str, ...]"
    +dependent_ids(task_id): "tuple[str, ...]"
    +roots(): "tuple[str, ...]"
    +leaves(): "tuple[str, ...]"
    +topological_order(): "tuple[str, ...]"
    +ready_ids(completed_ids, running_ids): "tuple[str, ...]"
    +workstream_ids(): "tuple[str, ...]"
    +workstream(workstream_id): WorkstreamSpec
    +tasks_in_workstream(workstream_id): "tuple[str, ...]"
    +child_workstream_ids(workstream_id): "tuple[str, ...]"
  }



  TaskGraphBuilder: "TaskGraphBuilder" {
    shape: class
    +from_yaml(path): TaskGraph
    +from_dict(data): TaskGraph
  }
}

# ─────────────────────────────────────────────
#  task_runtime/ — mutable execution state
# ─────────────────────────────────────────────
task_runtime_pkg: "task_runtime/" {
  TaskStatus: "TaskStatus <<enumeration>>" {
    shape: class
    PENDING
    RUNNING
    PR_CREATED
    PR_MERGED
    FAILED
  }

  TaskState: "TaskState <<mutable dataclass>>" {
    shape: class
    worktree_path: "Path | None"
    branch_name: "str | None"
    signal_dir: "Path | None"
    error: "str | None"
    attempt_num: int
    integration_branch: "str | None"
    workstream_worktree_path: "Path | None"
  }

  TaskArtifacts: "TaskArtifacts <<mutable dataclass>>" {
    shape: class
    pr_url: "str | None"
    concerns: "list[str]"
    ops_concerns: "list[str]"
    agent_address: "AgentAddress | None"
  }

  TaskRuntime: "TaskRuntime <<mutable dataclass>>" {
    shape: class
    task: Task
    state: TaskState
    artifacts: TaskArtifacts
    +status: TaskStatus
    +mark_pending(): void
    +mark_running(): void
    +mark_pr_created(): void
    +mark_pr_merged(): void
    +mark_failed(error): void
    +prepare_for_attempt(attempt_num): void
    +reset_for_retry(): void
  }

}

# ─────────────────────────────────────────────
#  task_runner/ — one-task lifecycle and I/O protocols
# ─────────────────────────────────────────────
task_runner_pkg: "task_runner/" {
  task_runner_core_pkg: "core/" {
    TearDownMode: "TearDownMode <<enumeration>>" {
      shape: class
      ALWAYS
      NEVER
      ON_SUCCESS
    }

    TaskCompletionSignal: "TaskCompletionSignal <<frozen dataclass>>" {
      shape: class
      outcome: "done | failed"
      pr_url: "str | None"
      error: "str | None"
      concerns: "tuple[str, ...]"
      ops_concerns: "tuple[str, ...]"
    }

    TaskPreparer: "TaskPreparer <<protocol>>" {
      shape: class
      +prepare(runtime): void
    }

    TaskLauncher: "TaskLauncher <<protocol>>" {
      shape: class
      +launch(runtime): Agent
    }

    TaskKickoff: "TaskKickoff <<protocol>>" {
      shape: class
      +kickoff(runtime, agent): void
    }

    TaskCompletionChecker: "TaskCompletionChecker <<protocol>>" {
      shape: class
      +wait_for_completion(runtime): TaskCompletionSignal
    }

    TaskMerger: "TaskMerger <<protocol>>" {
      shape: class
      +merge_pr(runtime, pr_url): void
    }

    TaskTeardown: "TaskTeardown <<protocol>>" {
      shape: class
      +teardown(runtime): void
    }

    StepDispatch: "StepDispatch<T> <<frozen dataclass>>" {
      shape: class
      entries: "dict[DispatchKey, Callable]"
      default: "Callable | None"
      +__call__(runtime): T
    }

    TaskRunResult: "TaskRunResult <<frozen dataclass>>" {
      shape: class
      task_id: str
      status: TaskStatus
      pr_url: "str | None"
      error: "str | None"
      failure_class: "IntegrationFailureClass | None"
    }

    TaskRunner: "TaskRunner <<protocol>>" {
      shape: class
      +run(runtime, teardown_mode): TaskRunResult
    }

    StandardTaskRunner: "StandardTaskRunner <<mutable dataclass>>" {
      shape: class
      on_event: "Callable[..., None] | None"
      +run(runtime, teardown_mode): TaskRunResult
    }
  }

  task_runner_impl_pkg: "implementations/" {
    "(6 classes hidden)"
  }
}

# ─────────────────────────────────────────────
#  orchestrator/ — async scheduling loop
# ─────────────────────────────────────────────
orchestrator_pkg: "orchestrator/" {
  TaskOutcomeClass: "TaskOutcomeClass <<enumeration>>" {
    shape: class
    SUCCESS
    EXPECTED_FAILURE
    INTERNAL_ERROR
  }

  OrchestratorOutcome: "OrchestratorOutcome <<enumeration>>" {
    shape: class
    SUCCEEDED
    COMPLETED_WITH_FAILURES
    FATAL_INTERNAL_ERROR
  }

  OrchestratorConfig: "OrchestratorConfig <<frozen dataclass>>" {
    shape: class
    max_concurrency: int
    max_task_attempts: int
    task_teardown_mode: TearDownMode
    fail_fast_on_internal_error: bool
    fail_fast_on_workstream_error: bool
  }

  OrchestratorEvent: "OrchestratorEvent <<frozen dataclass>>" {
    shape: class
    kind: str
    timestamp: float
    task_id: "str | None"
    workstream_id: "str | None"
    attempt_num: "int | None"
    outcome_class: "TaskOutcomeClass | None"
    message: "str | None"
  }

  OrchestratorResult: "OrchestratorResult <<frozen dataclass>>" {
    shape: class
    outcome: OrchestratorOutcome
    task_runtimes: "Mapping[str, TaskRuntime]"
    workstream_runtimes: "Mapping[str, WorkstreamRuntime]"
    events: "tuple[OrchestratorEvent, ...]"
    fatal_error: "str | None"
  }

  OrchestratorListener: "OrchestratorListener <<protocol>>" {
    shape: class
    +on_event(event): void
  }

  Orchestrator: "Orchestrator <<mutable dataclass>>" {
    shape: class
    graph: TaskGraph
    task_runner: TaskRunner
    workstream_runner: WorkstreamRunner
    config: OrchestratorConfig
    listener: "OrchestratorListener | None"
    +run(task_runtimes, workstream_runtimes): OrchestratorResult
  }


  TaskRuntimeBuilder: "TaskRuntimeBuilder" {
    shape: class
    +from_graph(graph): "dict[str, TaskRuntime]"
  }

  WorkstreamRuntimeBuilder: "WorkstreamRuntimeBuilder" {
    shape: class
    +from_graph(graph): "dict[str, WorkstreamRuntime]"
  }

  builders: "builders <<module>>" {
    shape: class
    module_path: orchestrator.builders
    "+build_standard_runner(...)": StandardTaskRunner
    "+build_standard_workstream_runner(...)": StandardWorkstreamRunner
  }
}

# ─────────────────────────────────────────────
