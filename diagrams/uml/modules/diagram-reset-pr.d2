direction: down
**.style.font-size: 50
*.style.font-size: 100

classes: {
  composition: {
    # NOTE: source-arrowhead.shape: diamond doesn't propagate via classes (D2 limitation)
    style.stroke: "#333333"
    style.stroke-width: 12
    style.font-size: 55
  }
  dependency: {
    target-arrowhead: {
      shape: arrow
      style.filled: false
    }
    style.stroke-dash: 3
    style.stroke-width: 12
    style.font-size: 55
  }
  inheritance: {
    target-arrowhead: {
      shape: triangle
      style.filled: false
    }
    style.stroke: "#333333"
    style.stroke-width: 12
    style.font-size: 55
  }
  implementation: {
    target-arrowhead: {
      shape: triangle
      style.filled: false
    }
    style.stroke-dash: 3
    style.stroke-width: 12
    style.font-size: 55
  }
}

# ─────────────────────────────────────────────
#  reset_pr.py — PR body update protocol + GH implementation
# ─────────────────────────────────────────────
reset_pr_py: "reset_pr.py" {
  PrBodyUpdater: "PrBodyUpdater <<protocol>>" {
    shape: class
    module_path: reset_pr
    +append_reset_activity(pr_url, entries): "list[str]"
  }
  GhPrBodyUpdater: "GhPrBodyUpdater" {
    shape: class
    module_path: reset_pr
    +append_reset_activity(pr_url, entries): "list[str]"
  }
  GhPrBodyUpdater -> PrBodyUpdater: satisfies { class: implementation }
}


# ─── External dependencies ───

ops_pkg: "ops/" {
  style.opacity: 0.5
  gh: "gh <<module>>" { shape: class }
}

reset_task_py: "reset_task.py" {
  style.opacity: 0.5
  reset_task_functions: "reset_task <<module>>" { shape: class }
}

reset_to_py: "reset_to.py" {
  style.opacity: 0.5
  reset_to_functions: "reset_to <<module>>" { shape: class }
}

reset_workstream_py: "reset_workstream.py" {
  style.opacity: 0.5
  reset_workstream_functions: "reset_workstream <<module>>" { shape: class }
}


# ─── Relationships ───

reset_task_py.reset_task_functions -> reset_pr_py.PrBodyUpdater: "append_reset_activity" { class: dependency }
reset_workstream_py.reset_workstream_functions -> reset_pr_py.PrBodyUpdater: "append_reset_activity" { class: dependency }
reset_to_py.reset_to_functions -> reset_pr_py.PrBodyUpdater: "append_reset_activity" { class: dependency }
reset_pr_py.GhPrBodyUpdater -> ops_pkg.gh: "pr_body, pr_update_body" { class: dependency }
