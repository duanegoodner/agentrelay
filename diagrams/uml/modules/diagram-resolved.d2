direction: down
**.style.font-size: 50
*.style.font-size: 100

classes: {
  composition: {
    # NOTE: source-arrowhead.shape: diamond doesn't propagate via classes (D2 limitation)
    style.stroke: "#333333"
    style.stroke-width: 12
    style.font-size: 55
  }
  dependency: {
    target-arrowhead: {
      shape: arrow
      style.filled: false
    }
    style.stroke-dash: 3
    style.stroke-width: 12
    style.font-size: 55
  }
  inheritance: {
    target-arrowhead: {
      shape: triangle
      style.filled: false
    }
    style.stroke: "#333333"
    style.stroke-width: 12
    style.font-size: 55
  }
  implementation: {
    target-arrowhead: {
      shape: triangle
      style.filled: false
    }
    style.stroke-dash: 3
    style.stroke-width: 12
    style.font-size: 55
  }
}

# ─────────────────────────────────────────────
#  resolved — frozen execution records
# ─────────────────────────────────────────────
resolved_py: "resolved.py" {
  InputFromSpec: "InputFromSpec <<frozen dataclass>>" {
    shape: class
    task: str
    category: "str | None"
  }

  TaggedPathSpec: "TaggedPathSpec <<frozen dataclass>>" {
    shape: class
    path: str
    category: str
  }

  ResolvedTask: "ResolvedTask <<frozen dataclass>>" {
    shape: class
    task_id: str
    workstream_id: str
    dependencies: "tuple[str, ...]"
    inputs_from: "tuple[InputFromSpec, ...]"
    role: str
    model: "str | None"
    tagged_paths: "tuple[TaggedPathSpec, ...]"
    branch_name: str
    integration_branch: str
    integration_branch_before_merge: "str | None"
    completed_at_attempt: int
    pr_url: "str | None"
    +to_dict(): dict
    +from_dict(d): ResolvedTask
  }

  ResolvedWorkstream: "ResolvedWorkstream <<frozen dataclass>>" {
    shape: class
    workstream_id: str
    integration_pr_url: "str | None"
    target_branch: str
    target_branch_before_any_merge: str
    merge_occurred: bool
    merged_at: "str | None"
    +to_dict(): dict
    +from_dict(d): ResolvedWorkstream
  }

  resolved_functions: "resolved_functions <<module>>" {
    shape: class
    module_path: resolved
    "+build_resolved_task(runtime, sha)": ResolvedTask
    "+build_resolved_workstream(ws_runtime)": ResolvedWorkstream
  }
}


# ─── External dependencies ───

orchestrator_pkg: "orchestrator/" {
  style.opacity: 0.5
  TaskProbe: "TaskProbe <<frozen dataclass>>" { shape: class }
  WorkstreamProbe: "WorkstreamProbe <<frozen dataclass>>" { shape: class }
  _OrchestratorRun: "_OrchestratorRun <<internal>>" { shape: class }
}

reset_ops_py: "reset_ops.py" {
  style.opacity: 0.5
  reset_ops_functions: "reset_ops <<module>>" { shape: class }
}

reset_task_py: "reset_task.py" {
  style.opacity: 0.5
  reset_task_functions: "reset_task <<module>>" { shape: class }
}

reset_to_py: "reset_to.py" {
  style.opacity: 0.5
  reset_to_functions: "reset_to <<module>>" { shape: class }
}

reset_workstream_py: "reset_workstream.py" {
  style.opacity: 0.5
  reset_workstream_functions: "reset_workstream <<module>>" { shape: class }
}

task_runner_pkg: "task_runner/" {
  style.opacity: 0.5
  task_runner_core_pkg: "core/" {
    StandardTaskRunner: "StandardTaskRunner" { shape: class }
  }
}

task_runtime_pkg: "task_runtime/" {
  style.opacity: 0.5
  TaskRuntime: "TaskRuntime <<mutable dataclass>>" { shape: class }
}

workstream_pkg: "workstream/" {
  style.opacity: 0.5
  workstream_core_pkg: "core/" {
    WorkstreamRuntime: "WorkstreamRuntime" { shape: class }
  }
}


# ─── Relationships ───

orchestrator_pkg.TaskProbe -> resolved_py.ResolvedTask: "resolved (optional)" { class: composition }
orchestrator_pkg.WorkstreamProbe -> resolved_py.ResolvedWorkstream: "resolved (optional)" { class: composition }
reset_ops_py.reset_ops_functions -> resolved_py.ResolvedWorkstream: "reads resolved.json" { class: dependency }
reset_task_py.reset_task_functions -> resolved_py.ResolvedTask: "reads resolved.json" { class: dependency }
reset_workstream_py.reset_workstream_functions -> resolved_py.ResolvedWorkstream: "reads resolved.json" { class: dependency }
reset_to_py.reset_to_functions -> resolved_py.ResolvedTask: "reads resolved.json" { class: dependency }
reset_to_py.reset_to_functions -> resolved_py.ResolvedWorkstream: "reads resolved.json" { class: dependency }
resolved_py.ResolvedTask -> resolved_py.InputFromSpec: inputs_from { class: composition }
resolved_py.ResolvedTask -> resolved_py.TaggedPathSpec: tagged_paths { class: composition }
resolved_py.resolved_functions -> resolved_py.ResolvedTask: builds { class: dependency }
resolved_py.resolved_functions -> resolved_py.ResolvedWorkstream: builds { class: dependency }
resolved_py.resolved_functions -> task_runtime_pkg.TaskRuntime: reads { class: dependency }
resolved_py.resolved_functions -> workstream_pkg.workstream_core_pkg.WorkstreamRuntime: reads { class: dependency }
task_runner_pkg.task_runner_core_pkg.StandardTaskRunner -> resolved_py.resolved_functions: "writes resolved.json" { class: dependency }
orchestrator_pkg._OrchestratorRun -> resolved_py.resolved_functions: "writes resolved.json" { class: dependency }
