direction: down
**.style.font-size: 50
*.style.font-size: 100

classes: {
  composition: {
    # NOTE: source-arrowhead.shape: diamond doesn't propagate via classes (D2 limitation)
    style.stroke: "#333333"
    style.stroke-width: 12
    style.font-size: 55
  }
  dependency: {
    target-arrowhead: {
      shape: arrow
      style.filled: false
    }
    style.stroke-dash: 3
    style.stroke-width: 12
    style.font-size: 55
  }
  inheritance: {
    target-arrowhead: {
      shape: triangle
      style.filled: false
    }
    style.stroke: "#333333"
    style.stroke-width: 12
    style.font-size: 55
  }
  implementation: {
    target-arrowhead: {
      shape: triangle
      style.filled: false
    }
    style.stroke-dash: 3
    style.stroke-width: 12
    style.font-size: 55
  }
}

# ─────────────────────────────────────────────
#  reset_to.py — batch rollback command
# ─────────────────────────────────────────────
reset_to_py: "reset_to.py" {
  BranchReset: "BranchReset <<frozen dataclass>>" {
    shape: class
    branch: str
    target_sha: str
    description: str
  }
  ResetToPlan: "ResetToPlan <<frozen dataclass>>" {
    shape: class
    target_kind: str
    target_id: str
    target_branch_reset: "BranchReset | None"
    integration_branch_resets: "tuple[BranchReset, ...]"
    tasks_to_reset: "tuple[str, ...]"
    workstreams_to_teardown: "tuple[str, ...]"
    workstreams_to_unmerge: "tuple[str, ...]"
    pr_urls_to_close: "tuple[str, ...]"
  }
  reset_to_functions: "reset_to <<module>>" {
    shape: class
    module_path: reset_to
    "+build_plan(graph_name, graph, run_dir, ...)": ResetToPlan
    "+format_plan(plan)": str
    "+execute_plan(graph_name, graph, run_dir, repo_path, plan, ...)": "list[str]"
  }
}


# ─── External dependencies ───

ops_pkg: "ops/" {
  style.opacity: 0.5
  gh: "gh <<module>>" { shape: class }
  git: "git <<module>>" { shape: class }
}

reset_ops_py: "reset_ops.py" {
  style.opacity: 0.5
  reset_ops_functions: "reset_ops <<module>>" { shape: class }
}

reset_pr_py: "reset_pr.py" {
  style.opacity: 0.5
  PrBodyUpdater: "PrBodyUpdater <<protocol>>" { shape: class }
}

resolved_py: "resolved.py" {
  style.opacity: 0.5
  ResolvedTask: "ResolvedTask <<frozen dataclass>>" { shape: class }
  ResolvedWorkstream: "ResolvedWorkstream <<frozen dataclass>>" { shape: class }
}

task_graph_pkg: "task_graph/" {
  style.opacity: 0.5
  TaskGraph: "TaskGraph <<frozen dataclass>>" { shape: class }
}


# ─── Relationships ───

reset_to_py.reset_to_functions -> reset_ops_py.reset_ops_functions: "shared utilities" { class: dependency }
reset_to_py.reset_to_functions -> reset_pr_py.PrBodyUpdater: "append_reset_activity" { class: dependency }
reset_to_py.reset_to_functions -> ops_pkg.gh: "pr_close_by_url" { class: dependency }
reset_to_py.reset_to_functions -> ops_pkg.git: "rev_parse, current_branch, checkout, clean" { class: dependency }
reset_to_py.reset_to_functions -> task_graph_pkg.TaskGraph: "task, dependent_ids, tasks_in_workstream" { class: dependency }
reset_to_py.reset_to_functions -> resolved_py.ResolvedTask: "reads resolved.json" { class: dependency }
reset_to_py.reset_to_functions -> resolved_py.ResolvedWorkstream: "reads resolved.json" { class: dependency }
