# ─────────────────────────────────────────────
#  task.py — immutable task specifications
# ─────────────────────────────────────────────
task_py: "task.py" {
  AgentRole: "AgentRole <<enumeration>>" {
    shape: class
    SPEC_WRITER
    TEST_WRITER
    TEST_REVIEWER
    IMPLEMENTER
    GENERIC
  }

  AgentFramework: "AgentFramework <<enumeration>>" {
    shape: class
    CLAUDE_CODE
  }

  AdrVerbosity: "AdrVerbosity <<enumeration>>" {
    shape: class
    NONE
    STANDARD
    DETAILED
    EDUCATIONAL
  }

  TaskPaths: "TaskPaths <<frozen dataclass>>" {
    shape: class
    src: "tuple[Path, ...]"
    test: "tuple[Path, ...]"
    spec: "Path | None"
  }

  AgentConfig: "AgentConfig <<frozen dataclass>>" {
    shape: class
    framework: AgentFramework
    model: "str | None"
    adr_verbosity: AdrVerbosity
    environment: AgentEnvironment
    isolation: "IsolationConfig | None"
  }

  ReviewConfig: "ReviewConfig <<frozen dataclass>>" {
    shape: class
    agent: AgentConfig
    review_on_attempt: int
  }

  InputFrom: "InputFrom <<frozen dataclass>>" {
    shape: class
    task: str
    category: "str | None"
  }

  Task: "Task <<frozen dataclass>>" {
    shape: class
    id: str
    role: AgentRole
    description: "str | None"
    paths: TaskPaths
    dependencies: "tuple[str, ...]"
    inputs_from: "tuple[InputFrom, ...]"
    completion_gate: "str | None"
    max_gate_attempts: "int | None"
    primary_agent: AgentConfig
    review: "ReviewConfig | None"
    workstream_id: str
    isolation: "IsolationConfig | None"
  }
}

# ─────────────────────────────────────────────
#  environments.py — execution environments
# ─────────────────────────────────────────────
environments_py: "environments.py" {
  AgentEnvironment: "AgentEnvironment <<type alias>>" {
    shape: class
  }

  TmuxEnvironment: "TmuxEnvironment <<frozen dataclass>>" {
    shape: class
    session: str
  }
}

# ─────────────────────────────────────────────
#  agent/ — agent abstractions
# ─────────────────────────────────────────────
agent_pkg: "agent/" {
  agent_core_pkg: "core/" {
    AgentAddress: "AgentAddress <<abstract>>" {
      shape: class
      +label(): str
      +capture_log(signal_dir): void
      +teardown(signal_dir, keep_panes): void
    }

    Agent: "Agent <<abstract>>" {
      shape: class
      +send_kickoff(instructions_path): void
      +address(): AgentAddress
    }
  }

  agent_impl_pkg: "implementations/" {
    TmuxAddress: "TmuxAddress <<frozen dataclass>>" {
      shape: class
      session: str
      pane_id: str
      +label(): str
      +capture_log(signal_dir): void
      +teardown(signal_dir, keep_panes): void
    }

    TmuxAgent: "TmuxAgent <<mutable dataclass>>" {
      shape: class
      -_address: TmuxAddress
      +address(): TmuxAddress
      +from_config(config, task_id, worktree_path, cmd): TmuxAgent
      +send_kickoff(instructions_path): void
    }
  }
}


# ─────────────────────────────────────────────
#  workstream/ — workstream specs, runtime, and runner
# ─────────────────────────────────────────────
workstream_pkg: "workstream/" {
  workstream_core_pkg: "core/" {
    WorkstreamSpec: "WorkstreamSpec <<frozen dataclass>>" {
      shape: class
      id: str
      parent_workstream_id: "str | None"
      base_branch: str
      merge_target_branch: str
      auto_merge: bool
      isolation: "IsolationConfig | None"
    }

    WorkstreamStatus: "WorkstreamStatus <<enumeration>>" {
      shape: class
      PENDING
      ACTIVE
      MERGE_READY
      PR_CREATED
      MERGED
      FAILED
    }

    WorkstreamState: "WorkstreamState <<mutable dataclass>>" {
      shape: class
      signal_dir: "Path | None"
      worktree_path: "Path | None"
      branch_name: "str | None"
      error: "str | None"
    }

    WorkstreamArtifacts: "WorkstreamArtifacts <<mutable dataclass>>" {
      shape: class
      merge_pr_url: "str | None"
      concerns: "list[str]"
      task_summaries: "list[TaskSummary]"
    }

    TaskSummary: "TaskSummary <<frozen dataclass>>" {
      shape: class
      task_id: str
      description: "str | None"
      pr_url: "str | None"
      concerns: "tuple[str, ...]"
      ops_concerns: "tuple[str, ...]"
    }

    WorkstreamRuntime: "WorkstreamRuntime <<mutable dataclass>>" {
      shape: class
      spec: WorkstreamSpec
      state: WorkstreamState
      artifacts: WorkstreamArtifacts
      +status(): WorkstreamStatus
      +mark_pending(): void
      +mark_active(): void
      +mark_merge_ready(): void
      +mark_pr_created(pr_url): void
      +mark_merged(): void
      +mark_failed(error): void
    }

    WorkstreamPreparer: "WorkstreamPreparer <<protocol>>" {
      shape: class
      +prepare_workstream(workstream_runtime): void
    }

    WorkstreamIntegrator: "WorkstreamIntegrator <<protocol>>" {
      shape: class
      +create_integration_pr(workstream_runtime): void
    }

    WorkstreamTeardown: "WorkstreamTeardown <<protocol>>" {
      shape: class
      +teardown_workstream(workstream_runtime): void
    }

    IntegrationMergeChecker: "IntegrationMergeChecker <<protocol>>" {
      shape: class
      +is_merged(workstream_runtime): bool
    }

    IntegrationAutoMerger: "IntegrationAutoMerger <<protocol>>" {
      shape: class
      +merge(workstream_runtime): void
    }

    WorkstreamRunResult: "WorkstreamRunResult <<frozen dataclass>>" {
      shape: class
      workstream_id: str
      status: WorkstreamStatus
      error: "str | None"
    }

    WorkstreamRunner: "WorkstreamRunner <<protocol>>" {
      shape: class
      +prepare(workstream_runtime): void
      +integrate(workstream_runtime): WorkstreamRunResult
      +teardown(workstream_runtime): void
    }

    StandardWorkstreamRunner: "StandardWorkstreamRunner <<mutable dataclass>>" {
      shape: class
      _preparer: WorkstreamPreparer
      _integrator: WorkstreamIntegrator
      _teardown: WorkstreamTeardown
      +prepare(workstream_runtime): void
      +integrate(workstream_runtime): WorkstreamRunResult
      +teardown(workstream_runtime): void
    }
  }

  workstream_impl_pkg: "implementations/" {
    GitWorkstreamPreparer: "GitWorkstreamPreparer <<dataclass>>" {
      shape: class
      repo_path: Path
      graph_name: str
      +prepare_workstream(workstream_runtime): void
    }

    GhWorkstreamIntegrator: "GhWorkstreamIntegrator <<dataclass>>" {
      shape: class
      repo_path: Path
      +create_integration_pr(workstream_runtime): void
    }

    GitWorkstreamTeardown: "GitWorkstreamTeardown <<dataclass>>" {
      shape: class
      repo_path: Path
      +teardown_workstream(workstream_runtime): void
    }

    GhIntegrationMergeChecker: "GhIntegrationMergeChecker <<dataclass>>" {
      shape: class
      +is_merged(workstream_runtime): bool
    }

    GhIntegrationAutoMerger: "GhIntegrationAutoMerger <<dataclass>>" {
      shape: class
      +merge(workstream_runtime): void
    }
  }
}

# ─────────────────────────────────────────────
#  task_graph/ — DAG structure and queries
# ─────────────────────────────────────────────
task_graph_pkg: "task_graph/" {
  TaskGraph: "TaskGraph <<frozen dataclass>>" {
    shape: class
    name: "str | None"
    max_workstream_depth: int
    +task(task_id): Task
    +task_ids(): "tuple[str, ...]"
    +dependency_ids(task_id): "tuple[str, ...]"
    +dependent_ids(task_id): "tuple[str, ...]"
    +roots(): "tuple[str, ...]"
    +leaves(): "tuple[str, ...]"
    +topological_order(): "tuple[str, ...]"
    +ready_ids(completed_ids, running_ids): "tuple[str, ...]"
    +workstream_ids(): "tuple[str, ...]"
    +workstream(workstream_id): WorkstreamSpec
    +tasks_in_workstream(workstream_id): "tuple[str, ...]"
    +child_workstream_ids(workstream_id): "tuple[str, ...]"
    +upstream_workstream_ids(task_id): "tuple[str, ...]"
  }

  _validation: "_validation <<module>>" {
    shape: class
    module_path: task_graph._validation
    +normalize_workstreams(workstreams_by_id): "dict[str, WorkstreamSpec]"
    +validate_task_workstream_ids(tasks_by_id, workstreams_by_id): void
    +validate_workstream_parent_ids_exist(workstreams_by_id): void
    +validate_workstream_hierarchy_acyclic(workstreams_by_id): void
    +validate_workstream_max_depth(workstreams_by_id, max_depth): void
    +validate_dependencies_exist(tasks_by_id, dependency_ids): void
    +validate_known_ids(ids, tasks_by_id, source_name): void
  }

  _indexing: "_indexing <<module>>" {
    shape: class
    module_path: task_graph._indexing
    +build_dependency_ids(tasks_by_id): "dict[str, tuple[str, ...]]"
    +build_dependent_ids(tasks_by_id, dependency_ids): "dict[str, tuple[str, ...]]"
    +topological_order_or_raise(dependency_ids, dependent_ids): "tuple[str, ...]"
    +build_task_ids_by_workstream(tasks_by_id, topological_order, workstreams_by_id): "dict[str, tuple[str, ...]]"
    +build_child_workstream_ids(workstreams_by_id): "dict[str, tuple[str, ...]]"
  }

  TaskGraphBuilder: "TaskGraphBuilder" {
    shape: class
    +from_yaml(path): TaskGraph
    +from_dict(data): TaskGraph
  }
}

# ─────────────────────────────────────────────
#  task_runtime/ — mutable execution state
# ─────────────────────────────────────────────
task_runtime_pkg: "task_runtime/" {
  TaskStatus: "TaskStatus <<enumeration>>" {
    shape: class
    PENDING
    RUNNING
    PR_CREATED
    PR_MERGED
    COMPLETED
    FAILED
  }

  TaskState: "TaskState <<mutable dataclass>>" {
    shape: class
    worktree_path: "Path | None"
    branch_name: "str | None"
    signal_dir: "Path | None"
    error: "str | None"
    attempt_num: int
    integration_branch: "str | None"
    workstream_worktree_path: "Path | None"
  }

  TaskArtifacts: "TaskArtifacts <<mutable dataclass>>" {
    shape: class
    pr_url: "str | None"
    concerns: "list[str]"
    ops_concerns: "list[str]"
    agent_address: "AgentAddress | None"
  }

  TaskRuntime: "TaskRuntime <<mutable dataclass>>" {
    shape: class
    task: Task
    state: TaskState
    artifacts: TaskArtifacts
    +status: TaskStatus
    +mark_pending(): void
    +mark_running(): void
    +mark_pr_created(): void
    +mark_pr_merged(): void
    +mark_completed(): void
    +mark_failed(error): void
    +prepare_for_attempt(attempt_num): void
    +reset_for_retry(): void
  }

}

# ─────────────────────────────────────────────
#  task_runner/ — one-task lifecycle and I/O protocols
# ─────────────────────────────────────────────
task_runner_pkg: "task_runner/" {
  task_runner_core_pkg: "core/" {
    TearDownMode: "TearDownMode <<enumeration>>" {
      shape: class
      ALWAYS
      NEVER
      ON_SUCCESS
    }

    TaskCompletionSignal: "TaskCompletionSignal <<frozen dataclass>>" {
      shape: class
      outcome: "done | failed"
      pr_url: "str | None"
      error: "str | None"
      concerns: "tuple[str, ...]"
      ops_concerns: "tuple[str, ...]"
    }

    TaskPreparer: "TaskPreparer <<protocol>>" {
      shape: class
      +prepare(runtime): void
    }

    TaskLauncher: "TaskLauncher <<protocol>>" {
      shape: class
      +launch(runtime): Agent
    }

    TaskKickoff: "TaskKickoff <<protocol>>" {
      shape: class
      +kickoff(runtime, agent): void
    }

    TaskCompletionChecker: "TaskCompletionChecker <<protocol>>" {
      shape: class
      +wait_for_completion(runtime): TaskCompletionSignal
    }

    GateCheckResult: "GateCheckResult <<frozen dataclass>>" {
      shape: class
      passed: bool
      output: str
    }

    TaskGateChecker: "TaskGateChecker <<protocol>>" {
      shape: class
      +check_gate(runtime): GateCheckResult
    }

    TaskMerger: "TaskMerger <<protocol>>" {
      shape: class
      +merge_pr(runtime, pr_url): void
    }

    TaskLogCapture: "TaskLogCapture <<protocol>>" {
      shape: class
      +capture_log(runtime): void
    }

    TaskTeardown: "TaskTeardown <<protocol>>" {
      shape: class
      +teardown(runtime): void
    }

    StepDispatch: "StepDispatch<T> <<frozen dataclass>>" {
      shape: class
      entries: "dict[DispatchKey, Callable]"
      default: "Callable | None"
      +__call__(runtime): T
    }

    TaskRunResult: "TaskRunResult <<frozen dataclass>>" {
      shape: class
      task_id: str
      status: TaskStatus
      pr_url: "str | None"
      error: "str | None"
      failure_class: "IntegrationFailureClass | None"
    }

    TaskRunner: "TaskRunner <<protocol>>" {
      shape: class
      +run(runtime, teardown_mode): TaskRunResult
    }

    StandardTaskRunner: "StandardTaskRunner <<mutable dataclass>>" {
      shape: class
      _preparer: "StepDispatch[TaskPreparer]"
      _launcher: "StepDispatch[TaskLauncher]"
      _kickoff: "StepDispatch[TaskKickoff]"
      _completion_checker: "StepDispatch[TaskCompletionChecker]"
      _gate_checker: TaskGateChecker
      _merger: "StepDispatch[TaskMerger]"
      _log_capture: "StepDispatch[TaskLogCapture]"
      _teardown: "StepDispatch[TaskTeardown]"
      on_event: "Callable[..., None] | None"
      +run(runtime, teardown_mode): TaskRunResult
    }
  }

  task_runner_impl_pkg: "implementations/" {
    WorktreeTaskPreparer: "WorktreeTaskPreparer <<dataclass>>" {
      shape: class
      repo_path: Path
      graph_name: str
      dependency_descriptions: dict
      context_content: "str | None"
      tools: "tuple[str, ...]"
      +prepare(runtime): void
    }

    TmuxTaskLauncher: "TmuxTaskLauncher <<dataclass>>" {
      shape: class
      +launch(runtime): Agent
    }

    TmuxTaskKickoff: "TmuxTaskKickoff <<dataclass>>" {
      shape: class
      +kickoff(runtime, agent): void
    }

    SignalCompletionChecker: "SignalCompletionChecker <<dataclass>>" {
      shape: class
      poll_interval: float
      +wait_for_completion(runtime): TaskCompletionSignal
    }

    ShellGateChecker: "ShellGateChecker <<dataclass>>" {
      shape: class
      +check_gate(runtime): GateCheckResult
    }

    GhTaskMerger: "GhTaskMerger <<dataclass>>" {
      shape: class
      repo_path: Path
      +merge_pr(runtime, pr_url): void
    }

    WorktreeTaskLogCapture: "WorktreeTaskLogCapture <<dataclass>>" {
      shape: class
      +capture_log(runtime): void
    }

    WorktreeTaskTeardown: "WorktreeTaskTeardown <<dataclass>>" {
      shape: class
      repo_path: Path
      keep_panes: bool
      +teardown(runtime): void
    }
  }
}

# ─────────────────────────────────────────────
#  orchestrator/ — async scheduling loop
# ─────────────────────────────────────────────
orchestrator_pkg: "orchestrator/" {
  TaskOutcomeClass: "TaskOutcomeClass <<enumeration>>" {
    shape: class
    SUCCESS
    EXPECTED_FAILURE
    INTERNAL_ERROR
  }

  OrchestratorOutcome: "OrchestratorOutcome <<enumeration>>" {
    shape: class
    SUCCEEDED
    COMPLETED_WITH_FAILURES
    FATAL_INTERNAL_ERROR
  }

  OrchestratorConfig: "OrchestratorConfig <<frozen dataclass>>" {
    shape: class
    max_concurrency: int
    max_task_attempts: int
    task_teardown_mode: TearDownMode
    fail_fast_on_internal_error: bool
    fail_fast_on_workstream_error: bool
    merge_poll_interval: float
  }

  OrchestratorEvent: "OrchestratorEvent <<frozen dataclass>>" {
    shape: class
    kind: str
    timestamp: float
    task_id: "str | None"
    workstream_id: "str | None"
    attempt_num: "int | None"
    outcome_class: "TaskOutcomeClass | None"
    message: "str | None"
  }

  OrchestratorResult: "OrchestratorResult <<frozen dataclass>>" {
    shape: class
    outcome: OrchestratorOutcome
    task_runtimes: "Mapping[str, TaskRuntime]"
    workstream_runtimes: "Mapping[str, WorkstreamRuntime]"
    events: "tuple[OrchestratorEvent, ...]"
    fatal_error: "str | None"
  }

  OrchestratorListener: "OrchestratorListener <<protocol>>" {
    shape: class
    +on_event(event): void
  }

  Orchestrator: "Orchestrator <<mutable dataclass>>" {
    shape: class
    graph: TaskGraph
    task_runner: TaskRunner
    workstream_runner: WorkstreamRunner
    config: OrchestratorConfig
    listener: "OrchestratorListener | None"
    integration_merge_checker: "IntegrationMergeChecker | None"
    integration_auto_merger: "IntegrationAutoMerger | None"
    +run(task_runtimes, workstream_runtimes): OrchestratorResult
  }

  _OrchestratorRun: "_OrchestratorRun <<internal>>" {
    shape: class
    -_orchestrator: Orchestrator
    +execute(): OrchestratorResult
  }

  TaskRuntimeBuilder: "TaskRuntimeBuilder" {
    shape: class
    +from_graph(graph): "dict[str, TaskRuntime]"
  }

  WorkstreamRuntimeBuilder: "WorkstreamRuntimeBuilder" {
    shape: class
    +from_graph(graph): "dict[str, WorkstreamRuntime]"
  }

  builders: "builders <<module>>" {
    shape: class
    module_path: orchestrator.builders
    "+build_standard_runner(...)": StandardTaskRunner
    "+build_standard_workstream_runner(...)": StandardWorkstreamRunner
  }
}

# ─────────────────────────────────────────────
#  ops/ — infrastructure primitives (private)
# ─────────────────────────────────────────────
ops_pkg: "ops/" {
  git: "git <<module>>" {
    shape: class
    module_path: ops.git
    +worktree_add(repo, path, branch, start_point): void
    +worktree_remove(repo, path): void
    +current_branch(repo): "str | None"
    +checkout(repo, branch): void
    +branch_create(repo, branch, start_point, force): void
    +branch_delete(repo, branch): void
    +pull_ff_only(repo): bool
    +fetch_branch(repo, branch): void
    +update_local_ref(repo, branch, remote_ref): void
    +push_branch(repo, branch, set_upstream): void
    +push_delete_branch(repo, branch): void
    +ls_remote_branch_exists(repo, branch): bool
    +set_config(repo, key, value): void
    +worktree_git_dir(worktree_path): Path
  }

  tmux: "tmux <<module>>" {
    shape: class
    module_path: ops.tmux
    +new_window(session, name, cwd): str
    +send_keys(pane_id, keys, press_enter): void
    +capture_pane(pane_id, full_history): str
    +kill_window(pane_id): void
    +wait_for_tui_ready(pane_id, marker, timeout): bool
  }

  gh: "gh <<module>>" {
    shape: class
    module_path: ops.gh
    +pr_create(repo_dir, title, body, base, head): str
    +pr_merge(pr_url): void
    +pr_body(pr_url): str
    +pr_is_merged(pr_url): bool
  }

  signals: "signals <<module>>" {
    shape: class
    module_path: ops.signals
    +ensure_signal_dir(signal_dir): Path
    +write_json(signal_dir, filename, data): void
    +write_text(signal_dir, filename, content): void
    +read_signal_file(signal_dir, filename): "str | None"
    +poll_signal_files(signal_dir, filenames, interval): str
  }

  docker: "docker <<module>>" {
    shape: class
    module_path: ops.docker
    +is_available(runtime): bool
    +image_exists(image, runtime): bool
    +network_exists(name, runtime): bool
    +network_create(name, runtime): void
    +network_remove(name, runtime): void
    +stop(container_name, runtime): void
    +rm(container_name, runtime): void
    +ps_by_label(label, runtime): "list[str]"
    +build_run_command(name, image, cmd, volumes, env_vars, labels): str
  }
}

# ─────────────────────────────────────────────
#  errors/ — error hierarchy
# ─────────────────────────────────────────────
errors_pkg: "errors/" {
  IntegrationBoundary: "IntegrationBoundary <<enumeration>>" {
    shape: class
    WORKSPACE
    SIGNAL
    PULL_REQUEST
    AGENT_LAUNCH
  }

  IntegrationFailureClass: "IntegrationFailureClass <<enumeration>>" {
    shape: class
    EXPECTED_TASK_FAILURE
    INTERNAL_ERROR
  }

  IntegrationError: "IntegrationError <<exception>>" {
    shape: class
    boundary: IntegrationBoundary
    failure_class: IntegrationFailureClass
  }

  ExpectedTaskFailureError: "ExpectedTaskFailureError <<exception>>" {
    shape: class
  }

  InternalIntegrationError: "InternalIntegrationError <<exception>>" {
    shape: class
  }

  _WorkspaceIntegrationError: "_WorkspaceIntegrationError <<exception>>" {
    shape: class
  }

  _SignalIntegrationError: "_SignalIntegrationError <<exception>>" {
    shape: class
  }

  _PullRequestIntegrationError: "_PullRequestIntegrationError <<exception>>" {
    shape: class
  }

  _AgentLaunchIntegrationError: "_AgentLaunchIntegrationError <<exception>>" {
    shape: class
  }

  error_functions: "error_functions <<module>>" {
    shape: class
    module_path: errors
    +classify_integration_error(exc): IntegrationFailureClass
  }
}

# ─────────────────────────────────────────────
#  agent_comm_protocol/ — agent communication protocol layers 1-3
# ─────────────────────────────────────────────
agent_comm_protocol_pkg: "agent_comm_protocol/" {
  TaskManifest: "TaskManifest <<frozen dataclass>>" {
    shape: class
    schema_version: str
    task_id: str
    role: AgentRole
    description: "str | None"
    src_paths: "tuple[Path, ...]"
    test_paths: "tuple[Path, ...]"
    spec_path: "Path | None"
    branch_name: str
    integration_branch: str
    attempt_num: int
    graph_name: "str | None"
    dependencies: "dict[str, DependencyInfo]"
    input_files: "tuple[InputFileInfo, ...]"
    tools: "tuple[str, ...]"
  }

  DependencyInfo: "DependencyInfo <<frozen dataclass>>" {
    shape: class
    description: "str | None"
  }

  InputFileInfo: "InputFileInfo <<frozen dataclass>>" {
    shape: class
    path: Path
    category: str
    source_task: str
  }

  WorkflowPolicies: "WorkflowPolicies <<frozen dataclass>>" {
    shape: class
    schema_version: str
    commit_policy: "_CommitPolicy | None"
    pr_policy: "_PrPolicy | None"
    completion_gate: "_CompletionGatePolicy | None"
    review: "_ReviewPolicy | None"
    adr: "_AdrPolicy | None"
    verification: "_VerificationPolicy | None"
  }

  _WorkflowAction: "_WorkflowAction <<str>>" {
    shape: class
    COMMIT_AND_PUSH
    CREATE_PR
    SIGNAL_DONE
    SIGNAL_FAILED
    RUN_COMPLETION_GATE
    RECORD_CONCERN
    WRITE_ADR
    RUN_VERIFICATION
  }

  _PrBodySection: "_PrBodySection <<str>>" {
    shape: class
    SUMMARY
    FILES_CHANGED
  }

  _CommitPolicy: "_CommitPolicy <<frozen dataclass>>" {
    shape: class
    action: _WorkflowAction
  }

  _PrPolicy: "_PrPolicy <<frozen dataclass>>" {
    shape: class
    action: _WorkflowAction
    base_branch: str
    title_template: str
    body_sections: "tuple[_PrBodySection, ...]"
  }

  _CompletionGatePolicy: "_CompletionGatePolicy <<frozen dataclass>>" {
    shape: class
    command: str
    max_attempts: int
    output_file: str
  }

  _VerificationPolicy: "_VerificationPolicy <<frozen dataclass>>" {
    shape: class
    commands: "tuple[str, ...]"
  }

  _AdrPolicy: "_AdrPolicy <<frozen dataclass>>" {
    shape: class
    verbosity: AdrVerbosity
  }

  _ReviewPolicy: "_ReviewPolicy <<frozen dataclass>>" {
    shape: class
    model: "str | None"
    review_on_attempt: int
  }

  manifest_functions: "manifest_functions <<module>>" {
    shape: class
    module_path: agent_comm_protocol.manifest
    "+build_manifest(task, ..., tools, input_files)": TaskManifest
    "+manifest_to_dict(manifest)": dict
  }

  policies_functions: "policies_functions <<module>>" {
    shape: class
    module_path: agent_comm_protocol.policies
    +build_policies(task, integration_branch, default_max_gate_attempts): WorkflowPolicies
    +policies_to_dict(policies): dict
  }

  templates_functions: "templates_functions <<module>>" {
    shape: class
    module_path: agent_comm_protocol.templates
    +resolve_instructions(role, manifest, adapter_name, adr_verbosity, sandbox_type, worktree_path, graph_yaml_path, signals_base_path): str
  }
}

# ─────────────────────────────────────────────
#  agent_sdk/ — agent-side helpers
# ─────────────────────────────────────────────
agent_sdk_pkg: "agent_sdk/" {
  TaskHelper: "TaskHelper <<class>>" {
    shape: class
    signal_dir: Path
    task_id: str
    branch_name: str
    integration_branch: str
    +from_env(): TaskHelper
    +complete(title, body): void
    +complete_without_pr(): void
    +create_pr(title, body): str
    +mark_done(pr_url): void
    +mark_failed(reason): void
    +record_concern(concern): void
    +record_ops_concern(concern): void
    +write_summary(message): void
    +declare_output(path, action, category): void
  }

  cli: "cli <<module>>" {
    shape: class
    module_path: agent_sdk.cli
    "+complete()": void
    "+complete_no_pr()": void
    "+failed()": void
    "+concern()": void
    "+ops_concern()": void
    "+summary()": void
    "+declare()": void
  }

  OutputAction: "OutputAction <<enumeration>>" {
    shape: class
    CREATED
    MODIFIED
    DELETED
  }

  OutputEntry: "OutputEntry <<frozen dataclass>>" {
    shape: class
    path: str
    action: OutputAction
    category: str
  }

  OutputManifest: "OutputManifest <<dataclass>>" {
    shape: class
    schema_version: str
    files: "list[OutputEntry]"
  }
}

# ─────────────────────────────────────────────
#  output/ — presentation layer
# ─────────────────────────────────────────────
output_pkg: "output/" {
  ConsoleListener: "ConsoleListener <<dataclass>>" {
    shape: class
    stream: TextIO
    verbose: bool
    +on_event(event): void
  }

  console_functions: "console <<module>>" {
    shape: class
    module_path: output.console
    "+print_summary(result, stream)": void
  }
}

# ─────────────────────────────────────────────
#  tools.py — declared tool validation and guidance
# ─────────────────────────────────────────────
tools_py: "tools.py" {
  ToolSpec: "ToolSpec <<frozen dataclass>>" {
    shape: class
    binary: str
    agent_guidance: str
  }

  ToolValidationError: "ToolValidationError <<exception>>" {
    shape: class
  }

  tools_functions: "tools <<module>>" {
    shape: class
    module_path: tools
    "+validate_tools(tools)": void
    "+tool_guidance(tools)": str
  }
}

# ─────────────────────────────────────────────
#  run_graph.py — top-level composition and CLI
# ─────────────────────────────────────────────
run_graph_py: "run_graph.py" {
  run_graph_functions: "run_graph <<module>>" {
    shape: class
    module_path: run_graph
    "+run_graph(graph_path, repo_path, ...)": OrchestratorResult
    "+dry_run(graph_path)": void
    "+main()": void
  }
}

# ─────────────────────────────────────────────
#  reset_graph.py — graph reset tool
# ─────────────────────────────────────────────
reset_graph_py: "reset_graph.py" {
  ResetPlan: "ResetPlan <<dataclass>>" {
    shape: class
    graph_name: str
    repo_path: Path
    start_head: str
    can_reset_main: bool
    open_prs: "list[dict]"
    remote_branches: "list[str]"
  }

  reset_graph_functions: "reset_graph <<module>>" {
    shape: class
    module_path: reset_graph
    "+plan_reset(graph_name, repo_path)": ResetPlan
    "+execute_reset(plan)": "list[str]"
    "+reset_graph(graph_name, repo_path, ...)": "list[str]"
    "+main()": void
  }
}

# ─────────────────────────────────────────────
#  sandbox/ — sandbox configuration and protocols
# ─────────────────────────────────────────────
sandbox_pkg: "sandbox/" {
  sandbox_core_pkg: "core/" {
    SandboxType: "SandboxType <<enumeration>>" {
      shape: class
      NONE
      OCI
    }

    ContainerRuntime: "ContainerRuntime <<enumeration>>" {
      shape: class
      DOCKER
      PODMAN
    }

    TokenTier: "TokenTier <<enumeration>>" {
      shape: class
      READ_ONLY
      STANDARD
      ELEVATED
    }

    CredentialType: "CredentialType <<enumeration>>" {
      shape: class
      API_KEY
      OAUTH
    }

    AnthropicCredential: "AnthropicCredential <<frozen dataclass>>" {
      shape: class
      name: str
      credential_type: CredentialType
      api_key: "str | None"
      oauth_path: "Path | None"
    }

    IsolationConfig: "IsolationConfig <<frozen dataclass>>" {
      shape: class
      sandbox_type: SandboxType
      token_tier: TokenTier
      image: "str | None"
      runtime: "ContainerRuntime | None"
    }

    SandboxContext: "SandboxContext <<frozen dataclass>>" {
      shape: class
      worktree_path: Path
      signal_dir: Path
      repo_path: Path
      task_id: str
      graph_name: str
      env_vars: "dict[str, str]"
    }

    AgentSandbox: "AgentSandbox <<protocol>>" {
      shape: class
      "+wrap_command(cmd, context)": str
      "+setup(context)": void
      "+teardown(context)": void
    }

    AgentFrameworkAdapter: "AgentFrameworkAdapter <<protocol>>" {
      shape: class
      "+build_command(config, signal_dir)": str
    }

    CredentialProvider: "CredentialProvider <<protocol>>" {
      shape: class
      "+resolve(tier)": "dict[str, str]"
    }
  }

  sandbox_impl_pkg: "implementations/" {
    NullSandbox: "NullSandbox" {
      shape: class
      "+wrap_command(cmd, context)": str
      "+setup(context)": void
      "+teardown(context)": void
    }

    OciSandbox: "OciSandbox" {
      shape: class
      "-_anthropic_credential": "AnthropicCredential | None"
      "+wrap_command(cmd, context)": str
      "+setup(context)": void
      "+teardown(context)": void
    }

    ClaudeCodeAdapter: "ClaudeCodeAdapter" {
      shape: class
      "+build_command(config, signal_dir)": str
    }

    NullCredentialProvider: "NullCredentialProvider" {
      shape: class
      "+resolve(tier)": "dict[str, str]"
    }

    FileCredentialProvider: "FileCredentialProvider" {
      shape: class
      path: Path
      "+resolve(tier)": "dict[str, str]"
    }
  }
}

